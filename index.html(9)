      const w = await idbGet("sidebarWidth");
      if(w && !isNaN(+w)) sidebar.style.width = Math.min(MAX, Math.max(MIN, +w)) + "px";
    }catch(e){}
  })();

  let dragging = false;
  function onMove(e){
    if(!dragging) return;
    const rect = sidebar.getBoundingClientRect();
    let w = Math.min(MAX, Math.max(MIN, e.clientX - rect.left));
    sidebar.style.width = w + "px";
  }
  function onUp(){
    if(!dragging) return;
    dragging = false;
    resizer.classList.remove("dragging");
    document.body.classList.remove("col-resizing");
    document.removeEventListener("mousemove", onMove);
    document.removeEventListener("mouseup", onUp);
    try{ idbSet("sidebarWidth", parseInt(sidebar.style.width)); }catch(e){}
  }
  resizer.addEventListener("mousedown", e=>{
    e.preventDefault();
    dragging = true;
    resizer.classList.add("dragging");
    document.body.classList.add("col-resizing");
    document.addEventListener("mousemove", onMove);
    document.addEventListener("mouseup", onUp);
  });
  resizer.addEventListener("dblclick", ()=>{       // double-click to reset
    sidebar.style.width = "230px";
    try{ idbSet("sidebarWidth", 230); }catch(e){}
  });
}

setupSidebarResizer();

/* ── Delivery table: arrow-key / Enter cell navigation ── */
function chkArrowNav(e){
  const el = e.target;
  if(!el || el.tagName!=="INPUT" || !el.classList.contains("chk-nav")) return;
  const key = e.key;
  if(key!=="Enter" && key!=="ArrowUp" && key!=="ArrowDown" && key!=="ArrowLeft" && key!=="ArrowRight") return;

  const isNum = el.type==="number";
  // For text inputs, only jump cells on Left/Right when the caret is at the text edge
  if(!isNum){
    let atStart=true, atEnd=true;
    try{
      atStart = el.selectionStart===0 && el.selectionEnd===0;
      atEnd   = el.selectionStart===el.value.length && el.selectionEnd===el.value.length;
    }catch(_){}
    if(key==="ArrowLeft"  && !atStart) return;
    if(key==="ArrowRight" && !atEnd)   return;
  } else {
    // number fields: let Left/Right edit the value normally
    if(key==="ArrowLeft" || key==="ArrowRight") return;
  }

  const inputs = Array.from(document.querySelectorAll("#checklist-card input.chk-nav"))
    .filter(i=>i.offsetParent!==null); // visible only
  if(inputs.length<2) return;

  const cur = el.getBoundingClientRect();
  const ccx = cur.left + cur.width/2, ccy = cur.top + cur.height/2;
  const ROW_TOL = 8;

  let best=null, bestScore=Infinity;
  for(const inp of inputs){
    if(inp===el) continue;
    const r = inp.getBoundingClientRect();
    const dx = (r.left + r.width/2) - ccx;
    const dy = (r.top  + r.height/2) - ccy;
    let ok=false, score=0;
    if(key==="ArrowDown" || key==="Enter"){
      if(dy > ROW_TOL){ ok=true; score = dy + Math.abs(dx)*3; }      // prefer same column
    } else if(key==="ArrowUp"){
      if(dy < -ROW_TOL){ ok=true; score = -dy + Math.abs(dx)*3; }
    } else if(key==="ArrowRight"){
      if(dx > 2 && Math.abs(dy) <= cur.height){ ok=true; score = dx + Math.abs(dy)*3; }
    } else if(key==="ArrowLeft"){
      if(dx < -2 && Math.abs(dy) <= cur.height){ ok=true; score = -dx + Math.abs(dy)*3; }
    }
    if(ok && score<bestScore){ bestScore=score; best=inp; }
  }
  if(best){
    e.preventDefault();
    best.focus();
    try{ best.select(); }catch(_){}   // select-all for quick overwrite
  }
}
document.addEventListener("keydown", chkArrowNav);

