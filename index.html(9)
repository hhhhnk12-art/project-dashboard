<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project Execution Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; font-family: 'Nunito', sans-serif; background: #f8f8f8; color: #111; }
  body { display: flex; flex-direction: column; }

  /* ── File connection bar ── */
  #file-conn-bar {
    height: 36px; flex-shrink: 0; display: flex; align-items: center; gap: 8px;
    padding: 0 14px; background: #1a0203; color: #fca5a5; font-size: 13px; font-weight: 700;
  }
  #file-conn-bar .conn-actions { margin-left: auto; display: flex; gap: 6px; }

  /* ── Layout ── */
  #app { display: flex; flex: 1; min-height: 0; overflow: hidden; }
  #sidebar {
    width: 230px; flex-shrink: 0; background: #1a0203;
    display: flex; flex-direction: column; padding: 16px 10px; gap: 6px; overflow: hidden;
  }
  #sb-proj-section { flex: 1 1 auto; min-height: 0; display: flex; flex-direction: column; }
  #proj-list { flex: 1 1 auto; min-height: 0; overflow-y: auto; }
  #sb-total-section { flex-shrink: 0; display: flex; flex-direction: column; gap: 6px; }
  #sb-total-section .sb-section-title { margin-bottom: 2px; text-align: left; padding-left: 2px; }
  #sb-total-section > button { width: 100%; box-sizing: border-box; margin-top: 0 !important; }
  #sidebar-resizer {
    width: 5px; flex-shrink: 0; cursor: col-resize; background: transparent;
    transition: background .15s; align-self: stretch;
  }
  #sidebar-resizer:hover, #sidebar-resizer.dragging { background: #C2000B; }
  body.col-resizing { cursor: col-resize; user-select: none; }
  #main { flex: 1; overflow-y: auto; padding: 14px 16px; }

  /* ── Sidebar ── */
  .sb-title { font-size: 12px; font-weight: 700; color: #fca5a5; letter-spacing: 1.5px; padding-left: 4px; margin-bottom: 4px; }
  .sb-hdr { display: flex; align-items: center; gap: 7px; padding: 0 8px 5px; border-bottom: 1px solid rgba(252,165,165,.18); margin-bottom: 4px; }
  .sb-hdr-wbs { width: 64px; flex-shrink: 0; text-align: center; font-size: 11px; font-weight: 700; color: #fca5a5; letter-spacing: 1px; }
  .sb-hdr-name { flex: 1; font-size: 11px; font-weight: 700; color: #fca5a5; letter-spacing: 1px; }
  .sb-section-title { font-size: 11px; font-weight: 800; color: #fca5a5; letter-spacing: 1.5px; padding: 4px 6px 6px; margin-top: 4px; text-transform: uppercase; border-bottom: 1px solid rgba(252,165,165,.25); margin-bottom: 8px; opacity: .85; }
  .sb-section + .sb-section { margin-top: 14px; }
  .sb-proj {
    display: flex; align-items: center; gap: 7px;
    padding: 7px 8px; border-radius: 10px; cursor: pointer; transition: background .15s;
  }
  .sb-proj:hover { background: rgba(194,0,11,.35); }
  .sb-proj.active { background: #C2000B; }
  .sb-wbs { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
  .sb-wbs-in {
    width: 26px; background: rgba(255,255,255,.1); border: 1px solid rgba(252,165,165,.25);
    border-radius: 4px; color: #fde68a; font-size: 11px; font-weight: 700; text-align: center;
    padding: 2px 1px; font-family: inherit;
  }
  .sb-wbs-in:focus { outline: none; border-color: #fca5a5; background: rgba(255,255,255,.2); }
  .sb-wbs-in::placeholder { color: rgba(252,165,165,.4); }
  .sb-wbs-sep { color: rgba(252,165,165,.55); font-size: 10px; font-weight: 700; }
  .sb-proj.active .sb-wbs-in { background: rgba(0,0,0,.18); border-color: rgba(255,255,255,.35); color: #fff; }
  .sb-proj.active .sb-wbs-sep { color: rgba(255,255,255,.7); }
  .sb-namecol { display: flex; align-items: center; gap: 7px; flex: 1; min-width: 0; }
  .sb-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
  .sb-name { font-size: 13px; font-weight: 700; color: #fca5a5; flex: 1; line-height: 1.3; word-break: break-all; }
  .sb-proj.active .sb-name { color: #fff; }
  .sb-proj.active .sb-dot { background: #fff !important; }
  .sb-del {
    background: rgba(255,255,255,.2); border: none; border-radius: 5px;
    color: #fff; font-size: 12px; cursor: pointer; padding: 1px 5px; font-family: inherit; display: none;
  }
  .sb-proj.active .sb-del { display: inline; }
  .sb-move { background: none; border: none; color: rgba(255,255,255,.5); font-size: 10px; cursor: pointer; padding: 0 2px; line-height: 1; display: none; }
  .sb-proj.active .sb-move { display: inline; }
  .sb-move:hover { color: #fff; }
  .sb-add {
    background: rgba(255,255,255,.08); color: #fca5a5;
    border: 1px dashed rgba(252,165,165,.4); border-radius: 10px;
    padding: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    text-align: center; font-family: inherit; margin-top: auto;
  }
  .sb-add:hover { background: rgba(255,255,255,.14); }
  .sb-total-del {
    background: rgba(124,58,237,.25); color: #c4b5fd;
    border: 1px solid rgba(196,181,253,.35); border-radius: 10px;
    padding: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    text-align: center; font-family: inherit;
  }
  .sb-total-del:hover { background: rgba(124,58,237,.4); }

  /* ── Total Delivery overlay ── */
  .td-overlay {
    display:none; position:fixed; inset:0; background:rgba(0,0,0,.55);
    z-index:1000; align-items:center; justify-content:center; padding:6px;
  }
  .td-overlay.show { display:flex; }
  .td-panel { background:#fff; border-radius:14px; width:100%; max-width:1500px; max-height:97vh; height:97vh; display:flex; flex-direction:column; overflow:hidden; }
  .td-hdr { background:#7C3AED; color:#fff; padding:12px 16px; display:flex; justify-content:space-between; align-items:center; font-weight:800; font-size:15px; flex-shrink:0; }
  .td-body { padding:10px 14px; overflow:auto; flex:1; }
  .td-tbl { width:100%; border-collapse:collapse; font-size:13px; }
  .td-tbl th { background:#7C3AED; color:#fff; padding:7px 10px; text-align:left; font-weight:700; white-space:nowrap; position:sticky; top:0; z-index:3; }
  .td-tbl th.sortable { cursor:pointer; user-select:none; }
  .td-tbl th.sortable:hover { background:#6D28D9; }
  .td-tbl td { padding:6px 10px; border-bottom:1px solid #f0f0f0; vertical-align:middle; }
  .td-tbl tr:nth-child(even) td { background:#fafafa; }
  .td-tbl tr:hover td { background:#F5F3FF; }
  .td-comment-input { width:100%; font-size:12px; border:1px solid #e5e7eb; border-radius:5px; padding:3px 6px; background:#fff; }
  .td-comment-input:focus { outline:none; border-color:#7C3AED; }
  .td-gr-o { color:#059669; font-weight:700; }
  .td-gr-x { color:#9ca3af; }
  .td-row-dim { opacity:.45; background:#f3f4f6; }
  .td-row-dim:hover { opacity:.7; }

  /* ── Total Timeline overlay ── */
  .sb-total-tl {
    background: rgba(3,105,161,.25); color: #93c5fd;
    border: 1px solid rgba(147,197,253,.35); border-radius: 10px;
    padding: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    text-align: center; font-family: inherit; margin-top: 6px;
  }
  .sb-total-tl:hover { background: rgba(3,105,161,.4); }
  .sb-total-iss {
    background: rgba(217,119,6,.22); color: #fcd34d;
    border: 1px solid rgba(252,211,77,.35); border-radius: 10px;
    padding: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    text-align: center; font-family: inherit; margin-top: 6px;
  }
  .sb-total-iss:hover { background: rgba(217,119,6,.38); }
  .sb-total-fin {
    background: rgba(4,120,87,.24); color: #6ee7b7;
    border: 1px solid rgba(110,231,183,.35); border-radius: 10px;
    padding: 8px; font-size: 13px; font-weight: 700; cursor: pointer;
    text-align: center; font-family: inherit; margin-top: 6px; width: 100%;
  }
  .sb-total-fin:hover { background: rgba(4,120,87,.4); }
  /* ── Project Financial Status view ── */
  .pf-tbl { width: 100%; border-collapse: separate; border-spacing: 0; }
  .pf-tbl th { font-size: 11px; color: #475569; font-weight: 800; text-transform: uppercase; letter-spacing: .4px;
    padding: 9px 8px; border-bottom: 2px solid #e2e8f0; text-align: center; position: sticky; top: 0; background: #fff; z-index: 5; box-shadow: 0 2px 0 #e2e8f0; }
  .pf-tbl th.pf-left, .pf-tbl td.pf-left { text-align: left; }
  .pf-tbl td { padding: 0; border-bottom: 1px solid #f1f5f9; font-size: 13px; }
  .pf-cellpad { padding: 9px 8px; }
  .pf-row-fill { position: relative; }
  .pf-fill-bg { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(16,185,129,.20), rgba(16,185,129,.12)); pointer-events: none; transition: width .25s ease; z-index: 0; }
  .pf-tbl td > * { position: relative; z-index: 1; }
  .pf-vessel { font-weight: 700; color: #0f172a; }
  .pf-proj { font-weight: 600; color: #1e293b; }
  .pf-pct { display: inline-block; min-width: 38px; font-weight: 800; font-size: 12px; color: #047857; margin-left: 8px; }
  .pf-chk-cell { text-align: center; }
  .pf-chk-cell .pf-cellpad { text-align: center; }
  .pf-yard { font-weight: 800; color: #0f172a; }
  .pf-yard-start td { border-top: 2px solid #cbd5e1; }
  .pf-proj-start td { border-top: 1.5px solid #e2e8f0; }
  .pf-chk { width: 18px; height: 18px; cursor: pointer; accent-color: #047857; }
  .pf-proj-grp td { background: #f8fafc; font-weight: 800; color: #334155; padding: 7px 8px; font-size: 12px; letter-spacing: .3px; }
  .ti-summary { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:14px; }
  .ti-sum-box { flex:1; min-width:90px; border-radius:10px; padding:9px 12px; text-align:center; border:1px solid; }
  .ti-sum-val { font-size:20px; font-weight:800; line-height:1.1; }
  .ti-sum-lbl { font-size:11px; font-weight:700; margin-top:2px; letter-spacing:.5px; }
  .ti-group { margin-bottom:18px; }
  .ti-group-hdr { display:flex; justify-content:space-between; align-items:center; font-size:13px; font-weight:800; letter-spacing:1px; padding:6px 12px; border-radius:8px; margin-bottom:10px; }
  .ti-count { font-size:12px; font-weight:800; background:rgba(0,0,0,.08); border-radius:20px; padding:1px 9px; }
  .ti-list { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:10px; }
  .ti-item { border:1px solid #e5e7eb; border-radius:10px; padding:10px 12px; background:#fff; }
  .ti-item-head { display:flex; align-items:center; gap:7px; flex-wrap:wrap; margin-bottom:6px; }
  .ti-proj { font-size:13px; font-weight:800; color:#111; }
  .ti-cat { font-size:11px; font-weight:700; color:#475569; background:#f1f5f9; border-radius:5px; padding:1px 7px; }
  .ti-status { font-size:11px; font-weight:600; color:#64748b; }
  .ti-upd-badge { font-size:11px; font-weight:700; color:#475569; background:#f1f5f9; border-radius:10px; padding:1px 8px; white-space:nowrap; }
  .ti-date { font-size:11px; color:#9ca3af; font-weight:600; margin-left:auto; white-space:nowrap; }
  .ti-desc { font-size:12.5px; color:#374151; line-height:1.45; white-space:pre-wrap; word-break:break-word; }
  .ti-desc.ti-empty { color:#cbd5e1; font-style:italic; }
  .ti-photo { display:block; margin-top:8px; max-width:100%; max-height:160px; border-radius:8px; border:1px solid #e5e7eb; cursor:pointer; object-fit:cover; }
  .ti-filter { cursor:pointer; transition:box-shadow .12s, transform .12s; }
  .ti-filter:hover { transform:translateY(-1px); }
  .ti-item { cursor:pointer; transition:box-shadow .12s, border-color .12s; }
  .ti-item:hover { border-color:#9ca3af; box-shadow:0 2px 10px rgba(0,0,0,.08); }
  .ti-desc-clip { display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .ti-thumb { display:block; margin-top:8px; width:100%; max-height:90px; border-radius:8px; border:1px solid #e5e7eb; object-fit:cover; }
  .ti-pri-badge { font-size:11px; font-weight:800; letter-spacing:.5px; padding:2px 9px; border-radius:20px; border:1px solid; }
  .ti-detail { background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:16px 18px; }
  .ti-detail-desc { font-size:14px; color:#1f2937; line-height:1.6; white-space:pre-wrap; word-break:break-word; margin-bottom:6px; }
  .ti-detail-photo { display:block; margin-top:12px; max-width:100%; max-height:440px; border-radius:10px; border:1px solid #e5e7eb; cursor:zoom-in; object-fit:contain; }
  .tt-summary { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:14px; }
  .tt-sum-box { flex:1; min-width:110px; background:#F0F9FF; border:1px solid #e0f2fe; border-radius:10px; padding:10px 12px; text-align:center; }
  .tt-sum-val { font-size:20px; font-weight:800; color:#0369A1; line-height:1.1; }
  .tt-sum-lbl { font-size:11px; font-weight:700; color:#64748b; margin-top:3px; letter-spacing:.5px; }
  .tt-risk-mini { display:inline-flex; gap:8px; align-items:center; justify-content:center; }
  .tt-risk-mini span { font-size:13px; font-weight:800; }
  .tt-proj-card { border:1px solid #e5e7eb; border-radius:12px; padding:11px 13px; margin-bottom:11px; background:#fff; cursor:pointer; transition:box-shadow .15s, border-color .15s; }
  .tt-proj-card:hover { border-color:#0369A1; box-shadow:0 2px 10px rgba(3,105,161,.12); }
  .tt-proj-head { display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:7px; }
  .tt-proj-name { font-size:14px; font-weight:800; color:#111; flex:1; min-width:140px; }
  .tt-risk { font-size:11px; font-weight:800; padding:2px 9px; border-radius:20px; white-space:nowrap; }
  .tt-prog { display:flex; align-items:center; gap:7px; min-width:170px; }
  .tt-bar { flex:1; height:8px; background:#e5e7eb; border-radius:5px; overflow:hidden; min-width:90px; }
  .tt-bar-fill { height:100%; background:#0369A1; border-radius:5px; }
  .tt-bar-pct { font-size:12px; font-weight:800; color:#0369A1; white-space:nowrap; }
  .tt-meta-row { display:flex; flex-wrap:wrap; gap:6px 14px; margin-bottom:8px; }
  .tt-milestone, .tt-next { font-size:11.5px; font-weight:600; color:#475569; }
  .tt-stage-strip { display:flex; gap:5px; overflow-x:auto; padding-bottom:3px; }
  .tt-stage { flex:1 0 86px; min-width:86px; padding:5px 3px; }
  .tt-stage .stage-pct { font-size:10.5px; }

  /* ── Common input/select ── */
  input, select, button, textarea { font-family: inherit; }
  .ei {
    border: 1.5px solid #FCA5A5; border-radius: 7px; padding: 3px 8px;
    font-size: 13px; background: #FFF5F5; color: #7f1d1d; outline: none; width: 100%;
  }
  .esel {
    border: 1.5px solid #FCA5A5; border-radius: 7px; padding: 3px 7px;
    font-size: 13px; background: #FFF5F5; color: #7f1d1d; outline: none; cursor: pointer;
  }
  .ei:focus, .esel:focus { border-color: #C2000B; }
  .esel option { background: #fff; color: #1a1a1a; }

  /* ── Buttons ── */
  .btn { background: #C2000B; color: #fff; border: none; border-radius: 8px; padding: 5px 13px; font-size: 13px; font-weight: 700; cursor: pointer; white-space: nowrap; }
  .btn-sm { padding: 3px 9px; font-size: 12px; }
  .btn-white { background: #fff; color: #C2000B; }
  .btn-ghost { background: rgba(255,255,255,.18); color: #fff; border: 1.5px solid rgba(255,255,255,.4); }
  .btn-ghost.active { background: #fff; color: #C2000B; border: none; }
  .btn-gray { background: #475569; }
  .btn-green { background: #059669; }
  .btn-amber { background: rgba(255,255,255,.2); color: #fff; border: none; border-radius: 8px; }

  /* ── Badges ── */
  .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 2px 7px; border-radius: 20px; border: 1px solid; }
  .badge-H { background: #FEE2E2; color: #991B1B; border-color: #F87171; }
  .badge-M { background: #FFFBEB; color: #92400E; border-color: #FCD34D; }
  .badge-L { background: #F0FDF4; color: #166534; border-color: #86EFAC; }

  /* ── Cards ── */
  .card { background: #fff; border: 1.5px solid #f0f0f0; border-radius: 14px; }
  .card-red { border-color: #FEE2E2; }

  /* ── Header ── */
  #dash-header {
    background: #C2000B; border-radius: 14px; padding: 11px 16px;
    margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;
  }
  .hdr-title { font-size: 21px; font-weight: 800; color: #fff; letter-spacing: .2px; margin-bottom: 5px; display:flex; align-items:center; flex-wrap:wrap; gap:4px; }
  .hdr-meta { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .hdr-meta span { font-size: 13px; color: #fecaca; font-weight: 500; }
  .hdr-meta b { color: #fff; }
  .hdr-actions { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .hdr-ei { font-size: 12px; background: rgba(255,255,255,.15); border: 1.5px solid rgba(255,255,255,.35); color: #fff; border-radius: 7px; padding: 3px 8px; outline: none; }
  .hdr-ei:focus { border-color: #fff; }
  .hdr-ei-sel { font-size: 12px; background: rgba(0,0,0,.35); border: 1.5px solid rgba(255,255,255,.35); color: #fff; border-radius: 7px; padding: 3px 6px; outline: none; }
  .hdr-ei-sel option { background: #1a0203; color: #fff; }

  /* ── Edit notice ── */
  #edit-notice {
    background: #FFF5F5; border: 1.5px solid #FCA5A5; border-radius: 10px;
    padding: 8px 13px; margin-bottom: 10px; font-size: 13px; color: #991B1B;
    display: none; align-items: center; gap: 8px;
  }
  #edit-notice.show { display: flex; }

  /* ── Save toast ── */
  #save-toast {
    position: fixed; bottom: 24px; right: 24px;
    background: #059669; color: #fff; font-size: 14px; font-weight: 700;
    padding: 10px 18px; border-radius: 10px; display: none;
    box-shadow: 0 4px 16px rgba(0,0,0,.15); z-index: 999;
  }
  #save-toast.show { display: block; }

  /* ── Timeline ── */
  #timeline-wrap { margin-bottom: 10px; }
  .tl-section-lbl { font-size: 13px; font-weight: 700; color: #C2000B; letter-spacing: 1.2px; }
  .tl-prog-bar { height: 7px; background: #FEE2E2; border-radius: 999px; overflow: hidden; margin: 8px 0 11px; }
  .tl-prog-fill { height: 100%; background: linear-gradient(90deg,#C2000B,#EF4444); border-radius: 999px; transition: width .4s; }
  #stages-grid { display: grid; gap: 4px; }
  .stage-box { border-radius: 10px; padding: 6px 4px; text-align: center; border: 1.5px solid; }
  .stage-dot { width: 8px; height: 8px; border-radius: 50%; margin: 0 auto 4px; }
  .stage-name { font-size: 11px; font-weight: 700; line-height: 1.2; margin-bottom: 2px; }
  .stage-pct { font-size: 11px; font-weight: 600; }
  .stage-date { font-size: 10.5px; color: #9ca3af; margin-top: 2px; font-weight: 500; }
  .stage-done   { background: #FFF5F5; border-color: #C2000B; }
  .stage-active { background: #FEE2E2; border-color: #C2000B; }
  .stage-delayed{ background: #FEE2E2; border-color: #7f1d1d; }
  .stage-planned{ background: #f9fafb; border-color: #e5e7eb; }
  .stage-done .stage-dot   { background: #C2000B; }
  .stage-active .stage-dot { background: #C2000B; box-shadow: 0 0 0 3px rgba(194,0,11,.2); }
  .stage-delayed .stage-dot{ background: #7f1d1d; }
  .stage-planned .stage-dot{ background: #d1d5db; }
  .stage-done .stage-name, .stage-active .stage-name { color: #991B1B; }
  .stage-delayed .stage-name { color: #7f1d1d; }
  .stage-planned .stage-name { color: #6b7280; }
  .stage-done .stage-pct, .stage-active .stage-pct { color: #C2000B; }
  .stage-planned .stage-pct { color: #9ca3af; }

  /* ── Bottom grid ── */
  #bottom-grid { display: grid; grid-template-columns: 1fr 310px; gap: 10px; align-items: start; }

  /* ── Category panel ── */
  #cats-wrap { margin-bottom: 10px; }
  .sec-lbl { font-size: 13px; font-weight: 700; color: #C2000B; letter-spacing: 1.2px; margin-bottom: 8px; }
  #filter-row { display: flex; gap: 5px; margin-bottom: 11px; flex-wrap: wrap; }
  .flt-btn {
    font-size: 12px; padding: 3px 10px; border-radius: 20px; cursor: pointer;
    border: 1.5px solid #d1d5db; background: transparent; color: #6b7280;
    font-weight: 700; transition: all .15s;
  }
  .flt-btn.active { background: #C2000B; color: #fff; border-color: #C2000B; }
  #cats-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 7px; }

  /* ── Category cards ── */
  .cat-card {
    border-radius: 12px; padding: 9px 11px;
    border: 1.5px solid #e5e7eb; background: #fff;
