function escapeHtml(value){ return esc(value); }

function getRiskClass(riskLevel, prefix){
  const p = prefix || "mail-risk-";
  const v = String(riskLevel||"").trim().toLowerCase();
  if(v==="red") return p+"red";
  if(v==="amber") return p+"amber";
  if(v==="green") return p+"green";
  return "";
}

function mailPriorityCls(p){
  return {Critical:"C",High:"H",Medium:"M",Low:"L"}[p] || "M";
}

function formatDateTime(value){
  if(!value) return "—";
  const d = new Date(value);
  if(isNaN(d.getTime())) return escapeHtml(value);
  return d.toLocaleString("ko-KR", {year:"numeric",month:"2-digit",day:"2-digit",hour:"2-digit",minute:"2-digit"});
}

function renderMailSummary(data){
  const list = (data !== undefined ? data : mailSummary) || [];
  const el = document.getElementById("mail-summary-list");
  const updatedEl = document.getElementById("mail-last-updated");
  if(!el) return;

  const sorted = [...list].sort((a,b)=> new Date(b.receivedDateTime||0) - new Date(a.receivedDateTime||0));
  const top20 = sorted.slice(0,20);

  if(!top20.length){
    el.innerHTML = `<div class="mail-empty">아직 요약된 메일이 없습니다.</div>`;
    if(updatedEl) updatedEl.textContent = "";
    return;
  }

  el.innerHTML = top20.map(m=>{
    const riskCls = getRiskClass(m.risk_level);
    const prioCls = mailPriorityCls(m.priority);
    const replyYes = String(m.reply_required||"").trim().toLowerCase()==="yes";
    return `<div class="mail-card ${riskCls}">
      <div class="mail-card-top">
        <span class="badge badge-${prioCls}">${escapeHtml(m.priority)||"—"}</span>
        <span class="mail-project">${escapeHtml(m.project)||"—"}</span>
        <span class="mail-time">${formatDateTime(m.receivedDateTime)}</span>
      </div>
      <div class="mail-subject">${escapeHtml(m.subject)||"(No subject)"}</div>
      <div class="mail-summary-text">${escapeHtml(m.summary_ko)}</div>
      <div class="mail-meta-row"><b>Action Required:</b> ${escapeHtml(m.action_required)||"—"}</div>
      <div class="mail-foot-row">
        <span>🏢 ${escapeHtml(m.customer_or_shipyard)||"—"}</span>
        <span>✉️ ${escapeHtml(m.from)||"—"}</span>
        <span class="${replyYes?"mail-reply-yes":"mail-reply-no"}">↩ Reply required: ${escapeHtml(m.reply_required)||"—"}</span>
      </div>
    </div>`;
  }).join("");

  if(updatedEl){
    updatedEl.textContent = `Latest: ${formatDateTime(top20[0].receivedDateTime)} · showing ${top20.length} of ${list.length}`;
  }
}

