/* ── TOTAL DELIVERY PIVOT ── */
let tdSortDir = -1; // 1=asc, -1=desc
let tdSortKey = "site"; // "delivery" | "site" | "eta"
let tdShowEta = true; // ETA PORT column visibility
let tdHideDelivered = true; // hide delivered (delivery=O) rows

const ORIGIN_THRESHOLDS_TD = {CN:14, EU:90, KR:7};

function calcWarnTd(it){
  if(it.delivery==="O") return null;
  const origin = it.origin||"CN";
  const threshold = ORIGIN_THRESHOLDS_TD[origin]??14;
  // Target deadline: Delivery Date if set; otherwise fall back to Site Required Date
  let target = parseTdDate(it.deliveryDate) || parseTdDate(it.siteRequiredDate);
  if(!target){
    return {daysLeft: null, origin, threshold};  // no usable date at all → 미정
  }
  target.setHours(0,0,0,0);
  const today = new Date(); today.setHours(0,0,0,0);
  const daysLeft = Math.floor((target - today) / (1000*60*60*24));
  return {daysLeft, origin, threshold};
}

function gatherDeliveryRows(){
  const rows = [];
  projects.forEach(proj=>{
    const d = projData[proj.id];
    if(!d || !d.deliveryChecklist) return;
    d.deliveryChecklist.forEach((grp, gi)=>{
      grp.items.forEach((it, ii)=>{
        rows.push({
          projId: proj.id,
          gi,
          ii,
          project: proj.name,
          shipyard: (d.meta&&d.meta.shipyard)||"",
          vessel: grp.name||"—",
          item: it.name||"—",
          siteRequiredDate: it.siteRequiredDate||"",
          etaPort: it.etaPort||"",
          deliveryDate: it.deliveryDate||"",
          delivered: it.delivery==="O",
          gr: it.gr||"X",
          comment: it.comment||"",
          warn: calcWarnTd(it)
        });
      });
    });
  });
  return rows;
}

function parseTdDate(s){
  if(!s) return null;
  const d = new Date(s);
  return isNaN(d.getTime()) ? null : d;
}

function renderTotalDelivery(){
  let rows = gatherDeliveryRows();
  if(tdHideDelivered) rows = rows.filter(r=>!r.delivered);  // hide delivered items
  const sortFieldMap = {site:"siteRequiredDate", eta:"etaPort", delivery:"deliveryDate"};
  const sortField = sortFieldMap[tdSortKey] || "deliveryDate";
  rows.sort((a,b)=>{
    const da = parseTdDate(a[sortField]), db = parseTdDate(b[sortField]);
    if(!da && !db) return 0;
    if(!da) return 1; if(!db) return -1;
    return tdSortDir * (da - db);
  });

  const arr = tdSortDir===1 ? "▲" : "▼";
  const siteArrow = tdSortKey==="site" ? " "+arr : "";
  const etaArrow  = tdSortKey==="eta" ? " "+arr : "";
  const delArrow  = tdSortKey==="delivery" ? " "+arr : "";
  const etaHead = tdShowEta ? `<th class="sortable" onclick="tdSort('eta')" title="정렬">ETA Port${etaArrow}</th>` : "";
  const html = rows.length===0
    ? `<div style="padding:20px;text-align:center;color:#9ca3af;">데이터가 없습니다.</div>`
    : `<table class="td-tbl">
        <thead><tr>
          <th style="width:52px;"></th>
          <th>Project</th>
          <th>Vessel</th>
          <th>Item</th>
          <th class="sortable" onclick="tdSort('site')" title="정렬">Site Required Date${siteArrow}</th>
          ${etaHead}
          <th class="sortable" onclick="tdSort('delivery')" title="정렬">Delivery Date${delArrow}</th>
          <th>GR</th>
          <th>Comment</th>
        </tr></thead>
        <tbody>${rows.map((r,idx)=>{
          const w = r.warn;
          let warnCell;
          if(w){
            const noDate  = w.daysLeft === null;
            const overdue = !noDate && w.daysLeft < 0;
            const label = noDate ? "미정" : overdue ? "OVER" : "D-"+w.daysLeft;
            const title = noDate
              ? `Delivery Date 미입력`
              : overdue
                ? `D+${Math.abs(w.daysLeft)} 초과`
                : `D-${w.daysLeft} 남음`;
            const cls = overdue ? " chk-warn-overdue" : noDate ? " chk-warn-nodate" : w.daysLeft <= w.threshold ? "" : " chk-warn-ok";
            warnCell = `<td style="text-align:center;padding:4px 3px;" title="${title}"><span class="chk-warn-badge${cls}">${label}</span></td>`;
          } else {
            warnCell = `<td></td>`;
          }
          const etaCell = tdShowEta ? `<td style="white-space:nowrap;">${esc(r.etaPort)||"—"}</td>` : "";
          return `<tr>
            ${warnCell}
            <td style="font-size:12px;color:#6b7280;white-space:nowrap;">
              <span class="sb-dot" style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${shipyardColor(r.shipyard)};margin-right:5px;vertical-align:middle;" title="${esc(r.shipyard)||"미설정"}"></span>${esc(r.project)}
            </td>
            <td style="font-weight:600;">${esc(r.vessel)}</td>
            <td>${esc(r.item)}</td>
            <td style="white-space:nowrap;">${esc(r.siteRequiredDate)||"—"}</td>
            ${etaCell}
            <td style="white-space:nowrap;font-weight:600;">${esc(r.deliveryDate)||"—"}</td>
            <td class="${r.gr==="O"?"td-gr-o":"td-gr-x"}">${r.gr}</td>
            <td><input class="td-comment-input" value="${esc(r.comment)}" placeholder="메모..."
              oninput="saveTdComment('${r.projId}',${r.gi},${r.ii},this.value)"></td>
          </tr>`;
        }).join("")}
        </tbody>
      </table>`;

  document.getElementById("td-table-wrap").innerHTML = html;
}

function tdToggleEta(show){
  tdShowEta = !!show;
  if(tdSortKey==="eta" && !tdShowEta){ tdSortKey = "delivery"; tdSortDir = 1; } // reset sort if hiding the sorted column
  renderTotalDelivery();
}

function tdToggleHide(on){
  tdHideDelivered = !!on;
  renderTotalDelivery();
}

function tdSort(key){
  if(tdSortKey===key){ tdSortDir *= -1; }   // same column → flip direction
  else { tdSortKey = key; tdSortDir = 1; }   // new column → ascending
  renderTotalDelivery();
}

function saveTdComment(projId, gi, ii, val){
  const d = projData[projId];
  if(d && d.deliveryChecklist[gi] && d.deliveryChecklist[gi].items[ii]){
    d.deliveryChecklist[gi].items[ii].comment = val;
  }
}

function openTotalDelivery(){
  tdSortKey = "site"; tdSortDir = 1; // default: Site Required Date, ascending
  const tg = document.getElementById("td-eta-toggle");
  if(tg) tg.checked = tdShowEta;
  const dg = document.getElementById("td-hide-toggle");
  if(dg) dg.checked = tdHideDelivered;
  renderTotalDelivery();
  document.getElementById("total-delivery-overlay").classList.add("show");
}

function closeTotalDelivery(){
  document.getElementById("total-delivery-overlay").classList.remove("show");
}

