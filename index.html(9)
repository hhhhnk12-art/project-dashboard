// 고정 가중치 (각 단계 100% 도달 시 Overall 누적값: KO 5 / Eng 10 / Mfg 30 / FAT 40 / Del 80 / Inst 90 / Comm 100)
const STAGE_WEIGHTS = {
  "Kick-off":5, "Engineering":5, "Manufacturing":20, "FAT":10,
  "Delivery":40, "Installation":10, "Commissioning":10, "Warranty":0
};
function stageWeight(d, i){
  const s = d.stages[i]; if(!s) return 0;
  const fixed = STAGE_WEIGHTS[(s.name||"").trim()];
  if(fixed!=null) return fixed;                    // 표준 단계는 고정값 사용
  if(s.weight!=null && !isNaN(+s.weight)) return +s.weight;
  return d.stages.length ? 100/d.stages.length : 0; // 그 외(사용자 추가 단계)는 균등
}
function computeStageOverall(d){
  if(!d || !d.stages || !d.stages.length) return 0;
  let totW = 0, acc = 0;
  d.stages.forEach((s,i)=>{
    const w = stageWeight(d,i);
    totW += w;
    const pct = s.status==="done" ? 100 : Math.min(100, Math.max(0, +s.pct||0));
    acc += (pct/100)*w;
  });
  if(totW<=0) return 0;
  // normalize to weight total so it always tops out at 100
  return Math.round(acc / totW * 100);
}
function isAutoProgress(d){
  return d && d.meta && d.meta.autoProgress!==false; // default ON (true) unless explicitly false
}
function refreshOverall(d){
  if(isAutoProgress(d)) d.meta.progress = computeStageOverall(d);
}
function toggleAutoProgress(){
  const d = getCurrent(); if(!d) return;
  d.meta.autoProgress = !isAutoProgress(d);
  if(isAutoProgress(d)) d.meta.progress = computeStageOverall(d);
  renderTimeline();
}
function setStageStatus(i, val){
  const d = getCurrent(); if(!d || !d.stages[i]) return;
  d.stages[i].status = val;
  if(val==="done") d.stages[i].pct = 100;   // auto-fill to 100% when marked done
  refreshOverall(d);
  renderTimeline();
}
function setStagePct(i, val){
  const d = getCurrent(); if(!d || !d.stages[i]) return;
  const pct = Math.min(100, Math.max(0, +val||0));
  d.stages[i].pct = pct;
  if(pct===100) d.stages[i].status = "done";   // auto-mark done when 100%
  refreshOverall(d);
  renderTimeline();
}
function renderTimeline(){
  const d = getCurrent(); if(!d) return;
  const m = d.meta;

  // progress
  const auto = isAutoProgress(d);
  if(auto) m.progress = computeStageOverall(d);   // keep in sync in auto mode
  document.getElementById("tl-fill").style.width = m.progress+"%";
  const tlRight = document.getElementById("tl-right");
  const autoBtn = `<button class="btn btn-sm" style="padding:2px 9px;font-size:11px;font-weight:700;background:${auto?"#C2000B":"#e5e7eb"};color:${auto?"#fff":"#374151"};" 
      onclick="toggleAutoProgress()" title="${auto?"단계 진행률로 자동 계산 중 — 클릭 시 수동 입력":"수동 입력 중 — 클릭 시 단계 기반 자동 계산"}">${auto?"AUTO":"MANUAL"}</button>`;
  if(auto){
    tlRight.innerHTML = `
      ${autoBtn}
      <span id="tl-pct-lbl" style="font-size:13px;font-weight:700;color:#C2000B">Overall: ${m.progress}%</span>
      <span style="font-size:11px;color:#9ca3af;">(단계 진행률 기반)</span>`;
  } else if(editMode){
    tlRight.innerHTML = `
