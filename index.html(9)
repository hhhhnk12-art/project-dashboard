  const title = ((typeof buildProjectTitle==="function" ? buildProjectTitle(m) : "") || m.name || "Project");

  // Timeline
  const overall = isAutoProgress(d) ? computeStageOverall(d) : (Number(m.progress)||0);
  const stagesRows = (d.stages||[]).map(s=>
    `<tr><td>${esc(s.name)}</td><td class="c">${esc(s.status)}</td><td class="c">${s.status==="done"?100:(Number(s.pct)||0)}%</td><td class="c">${esc(s.date)||"-"}</td></tr>`).join("");

  // Issues
  const cats = d.cats||[];
  const concern = cats.filter(c=>String(c.priority)==="High" && c.status!=="Closed");
  const concernList = concern.length ? concern.map(c=>{
    const last=(c.issues||[]).slice(-1)[0];
    return `<li><b>${esc(c.name)}</b> (${esc(c.status)})${last&&last.desc?` &mdash; ${esc(last.desc)}`:""}</li>`;
  }).join("") : "<li>-</li>";
  const actions = ((d.summary&&d.summary.actions)||[]).filter(x=>x&&x.trim());
  const actionList = actions.length ? actions.map(a=>`<li>${esc(a)}</li>`).join("") : "<li>-</li>";
  const criticals = ((d.summary&&d.summary.criticals)||[]).filter(x=>x&&x.trim());
  const criticalList = criticals.length ? criticals.map(a=>`<li>${esc(a)}</li>`).join("") : "<li>-</li>";

  const issueRows = cats.length ? cats.map(c=>{
    const last=(c.issues||[]).slice(-1)[0];
