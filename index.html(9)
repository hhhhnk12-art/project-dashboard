      상태
      <select class="esel" style="font-size:12px;" onchange="tiSetStatus(this.value)">${statusOpts}</select>
    </label>
  </div>`;

  const showKeys = (tiFilter==="all") ? orderedKeys : orderedKeys.filter(k=>k===tiFilter);
  if(showKeys.length===0){
    wrap.innerHTML = statusBar + `<div style="padding:20px;text-align:center;color:#9ca3af;">해당 조건의 이슈가 없습니다.</div>`;
    return;
  }
  wrap.innerHTML = statusBar + showKeys.map(key=>{
    const meta = priMeta(key);
    const list = groups[key];
