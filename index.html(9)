      const dateLabel = s.date ? `<div class="stage-date">${esc(s.date)}</div>` : "";
      return `<div class="${sc} stage-box tt-stage">
        <div class="stage-dot"></div>
        <div class="stage-name">${esc(s.name)}</div>
        <div class="stage-pct" style="color:${s.status==="done"||s.status==="active"?"#C2000B":"#9ca3af"}">${pctLabel}</div>
        ${dateLabel}
      </div>`;
    }).join("");

    const milestone = m.milestone ? `<span class="tt-milestone">🏁 ${esc(m.milestone)}</span>` : "";
    const nextplan  = m.nextplan  ? `<span class="tt-next">▶ Next: ${esc(m.nextplan)}</span>` : "";
    const metaRow = (milestone||nextplan) ? `<div class="tt-meta-row">${milestone}${nextplan}</div>` : "";

