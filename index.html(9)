      <span style="font-size:12px;color:#6b7280;font-weight:600">Overall:</span>
      <input type="number" class="ei" style="width:50px;font-size:13px" value="${m.progress}"
        oninput="getCurrent().meta.progress=Math.min(100,Math.max(0,+this.value));document.getElementById('tl-fill').style.width=this.value+'%';document.getElementById('tl-pct-lbl').textContent='Overall: '+this.value+'%'">
      <span style="font-size:12px;color:#6b7280;font-weight:600">%</span>
      <span id="tl-pct-lbl" style="font-size:13px;font-weight:700;color:#C2000B">Overall: ${m.progress}%</span>`;
  } else {
    tlRight.innerHTML = `
      ${autoBtn}
      <span id="tl-pct-lbl" style="font-size:13px;font-weight:700;color:#C2000B">Overall: ${m.progress}%</span>`;
  }

  // stages
  const grid = document.getElementById("stages-grid");
  grid.style.gridTemplateColumns = `repeat(${d.stages.length},1fr)`;
  grid.innerHTML = d.stages.map((s,i)=>{
    const sc = stageClass(s.status);
    const pctLabel = s.status==="done" ? "✓ 100%" : s.pct>0 ? s.pct+"%" : "–";
    if(editMode){
      return `<div class="${sc} stage-box" style="padding:5px 3px;">
        <input class="ei" style="font-size:11px;margin-bottom:3px;font-weight:700" value="${esc(s.name)}"
