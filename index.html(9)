/* ── FINANCIAL: VO (Variation Order) contract value history ── */
const CURRENCY_SYMBOLS = {USD:"$", EUR:"€", KRW:"₩", JPY:"¥", GBP:"£", CNY:"¥"};

// Ensure d.seriesFinancial has the right number of entries
function ensureSeriesFinancial(d){
  const count = Math.max(1, parseInt(d.meta.seriesCount)||0);
  if(!d.seriesFinancial) d.seriesFinancial = [];
  while(d.seriesFinancial.length < count){
    // migrate existing summary data into first slot when first created
    if(d.seriesFinancial.length===0 && d.summary.voHistory && d.summary.voHistory.length){
      d.seriesFinancial.push({
        voHistory: JSON.parse(JSON.stringify(d.summary.voHistory)),
        decisions: JSON.parse(JSON.stringify(d.summary.decisions||[])),
        currency: d.summary.currency||"USD"
      });
    } else {
      d.seriesFinancial.push({voHistory:[], decisions:[], currency: d.seriesFinancial[0]?.currency||"USD"});
    }
  }
  return d.seriesFinancial;
}

// Returns the financial object for the currently selected series (or series 0 for ALL view)
function getActiveFinancial(d){
  const count = parseInt(d.meta.seriesCount)||0;
  if(!count) return d.summary; // no series mode — use legacy summary
  ensureSeriesFinancial(d);
  const idx = selFinancialIdx===-1 ? 0 : selFinancialIdx;
  return d.seriesFinancial[Math.min(idx, d.seriesFinancial.length-1)];
}

// Applies fn to just the selected series, or ALL series when selFinancialIdx===-1
function applyToFinancial(fn){
  const d = getCurrent();
  const count = parseInt(d.meta.seriesCount)||0;
  if(!count){ fn(d.summary, -1); return; }
  ensureSeriesFinancial(d);
  if(selFinancialIdx===-1){
    d.seriesFinancial.forEach((sf,i)=>fn(sf,i));
  } else {
    fn(d.seriesFinancial[selFinancialIdx], selFinancialIdx);
  }
}

function currencySymbol(){
  const d = getCurrent();
  const sf = getActiveFinancial(d);
  const code = (sf && sf.currency) || "USD";
  return CURRENCY_SYMBOLS[code] || (code+" ");
}
function fmtMoney(n){ return currencySymbol() + (Number(n)||0).toLocaleString("en-US"); }
function fmtSigned(n){
  const v = Number(n)||0;
  const sign = v>0 ? "+" : v<0 ? "-" : "";
  return sign + currencySymbol() + Math.abs(v).toLocaleString("en-US");
}

// VO change amount: prefer explicit delta; fall back to old before/after data
function voDelta(v){
  if(v.delta!==undefined && v.delta!==null && v.delta!=="") return Number(v.delta)||0;
  return (Number(v.after)||0) - (Number(v.before)||0);
}

function renderFinancial(){
  const d = getCurrent(); if(!d) return;
  const el = document.getElementById("sum-decisions");
  const seriesCount = parseInt(d.meta.seriesCount)||0;

  // Build series dropdown if seriesCount is set
  let seriesDropdown = "";
  if(seriesCount > 0){
    ensureSeriesFinancial(d);
    const seriesOpts = `<option value="-1"${selFinancialIdx===-1?" selected":""}>ALL</option>`
      + Array.from({length:seriesCount},(_,i)=>`<option value="${i}"${selFinancialIdx===i?" selected":""}>#${i+1}</option>`).join("");
    const allNote = selFinancialIdx===-1 && editMode ? `<span style="font-size:10px;color:#059669;font-weight:700;margin-left:6px;">✎ 전체 적용</span>` : "";
