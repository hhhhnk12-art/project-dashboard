          + `<td>${projFirst?esc(p.name):""}</td>`
          + `<td>${esc(g.name)||"Untitled"}</td>`
          + `<td class="c">${ox(fs.dp)}</td><td class="c">${ox(fs.delivery)}</td><td class="c">${ox(fs.fnbl)}</td>`
          + `<td class="c">${ox(fs.retention)}</td><td class="c">${ox(fs.allPaid)}</td>`
