  };
  reader.readAsDataURL(file);
}
function handleUpdatePhoto(catIdx, issueIdx, inputEl){
  const file = inputEl.files && inputEl.files[0];
  setUpdatePhotoFile(catIdx, issueIdx, file);
}
function handleUpdateDrop(catIdx, issueIdx, ev){
  ev.preventDefault();
  if(ev.currentTarget && ev.currentTarget.classList) ev.currentTarget.classList.remove("drag-over");
  const dt = ev.dataTransfer; if(!dt) return;
  let file = null;
  if(dt.files && dt.files.length){ file = dt.files[0]; }
  else if(dt.items){ for(const it of dt.items){ if(it.kind==="file"){ file = it.getAsFile(); break; } } }
  if(file) setUpdatePhotoFile(catIdx, issueIdx, file);
}
function handleUpdatePaste(catIdx, issueIdx, ev){
  const items = (ev.clipboardData && ev.clipboardData.items) || [];
  for(const it of items){
    if(it.kind==="file" && it.type && it.type.startsWith("image/")){
      const file = it.getAsFile();
      if(file){ ev.preventDefault(); setUpdatePhotoFile(catIdx, issueIdx, file); return; }
    }
  }
}

let lightboxScale = 1; // 1 = fit (base 75vw / 80vh)
