    return;
  }

  // ── summary ──
  let sumProg = 0;
  const rc = {RED:0, AMBER:0, GREEN:0};
  projects.forEach(p=>{
    const d = projData[p.id]; if(!d) return;
    sumProg += (+d.meta.progress||0);
    const r = String(d.meta.risk||"").toUpperCase();
    if(rc[r]!==undefined) rc[r]++;
