      <div class="tt-sum-val tt-risk-mini">
        <span style="color:#C2000B">R ${rc.RED}</span>
        <span style="color:#D97706">A ${rc.AMBER}</span>
        <span style="color:#059669">G ${rc.GREEN}</span>
      </div>
      <div class="tt-sum-lbl">RISK BREAKDOWN</div>
    </div>`;

  // ── per-project timeline cards ──
  wrap.innerHTML = projects.map(p=>{
    const d = projData[p.id];
