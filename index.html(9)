    return;
  }

  // ── LIST VIEW (grouped by priority, with priority + status filters) ──
  items.forEach((it,idx)=>{ it._idx = idx; });   // stable indices into full cache
  const visible = items.filter(it => tiStatusFilter==="all" || (it.catStatus||"")===tiStatusFilter);
  const groups = {};
  visible.forEach(it=>{ (groups[it.priority] = groups[it.priority]||[]).push(it); });
  const orderedKeys = Object.keys(groups).sort((a,b)=>priMeta(a).rank-priMeta(b).rank);

  // filter chips (also serve as count summary)
  const allActive = tiFilter==="all";
  let sumHtml = `<div class="ti-sum-box ti-filter${allActive?" active":""}" onclick="tiSetFilter('all')"
      style="${allActive?'border-color:#374151;box-shadow:0 0 0 2px #37415133;':'border-color:#e5e7eb;'}">
      <div class="ti-sum-val" style="color:#374151">${visible.length}</div>
      <div class="ti-sum-lbl" style="color:#374151">ALL</div></div>`;
  sumHtml += orderedKeys.map(key=>{
    const m=priMeta(key); const active=tiFilter===key;
    return `<div class="ti-sum-box ti-filter${active?" active":""}" onclick="tiSetFilter('${key}')"
