function ttProgressBar(pct){
  pct = Math.max(0, Math.min(100, +pct||0));
  return `<div class="tt-bar"><div class="tt-bar-fill" style="width:${pct}%"></div></div>
          <span class="tt-bar-pct">${pct}%</span>`;
