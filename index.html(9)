async function saveAiKey(){
  const provider = document.getElementById("ai-provider").value || "gemini";
  const key = document.getElementById("ai-key").value.trim();
  const model = (document.getElementById("ai-model").value.trim()) || AI_DEFAULT_MODEL[provider];
  try{
    await idbSet("aiProvider", provider);
    await idbSet(aiKeySlot(provider), key);
    await idbSet(aiModelSlot(provider), model);
    if(provider==="compatible"){
      const base = (document.getElementById("ai-baseurl").value.trim()) || AI_DEFAULT_BASE.compatible;
      await idbSet("compatBaseUrl", base);
    }
  }catch(e){}
  document.getElementById("ai-key-status").textContent = "✓ 저장됨";
