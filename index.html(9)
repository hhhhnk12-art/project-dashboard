async function refreshFromFile(){
  if(!fileHandle) return;
  await loadFromFile();
}

async function loadFromFile(){
  try{
    const file = await fileHandle.getFile();
    const text = await file.text();
    const data = text.trim() ? JSON.parse(text) : null;
    if(data && data.projects && data.projects.length){
      projects = data.projects;
      projData = data.projData || {};
      activeId = projects[0].id;
      lastStamp = data._stamp || file.lastModified;
    } else {
      const pid = "proj_"+Date.now();
      const s = sampleProject();
      projects = [{id:pid,name:s.meta.name,color:BRAND,wbsStart:"",wbsEnd:""}];
      projData = {[pid]: s};
      activeId = pid;
    }
    mailSummary = (data && Array.isArray(data.mailSummary)) ? data.mailSummary : [];
    editMode = false; selCatId = null; filterBy = "all";
    collapseAllVessels(); migrateIssueStatuses(); // collapse vessels + drop legacy Open status
    baseSnapshot = snapshotState();   // common ancestor for 3-way merge
    setConnUI("connected", fileHandle.name);
    render();
  }catch(e){
    console.error("loadFromFile error:", e);
    alert("There was a problem reading the file. Please reconnect.\n\n(Details: " + (e && e.message ? e.message : e) + ")");
    setConnUI("disconnected");
  }
}

async function writeToFile(opts){
  const silent = opts && opts.silent;
  if(!fileHandle){
    if(!silent) alert("Please connect a data file first using 'Open Existing File' or 'Create New File'.");
    return false;
  }
  try{
    let perm = await fileHandle.queryPermission({mode:"readwrite"});
    if(perm !== "granted" && !silent) perm = await fileHandle.requestPermission({mode:"readwrite"});
    if(perm !== "granted"){ if(!silent) alert("Save permission was denied."); return false; }
  }catch(e){ if(!silent) alert("An error occurred while checking save permission."); return false; }

  // Optimistic concurrency: if a teammate saved since my last sync, MERGE their changes
  // into mine (3-way) instead of overwriting. Only truly-conflicting same fields are flagged.
  pollBusy = true;
  try{
    const current = await fileHandle.getFile();
    const onDiskText = await current.text();
    const onDisk = onDiskText.trim() ? JSON.parse(onDiskText) : null;
    if(onDisk && onDisk._stamp && lastStamp && onDisk._stamp !== lastStamp){
      const { conflicts } = mergeDiskIntoMemory(onDisk);
      render();
      if(!silent && conflicts.length){
        alert("팀원이 그 사이 저장한 변경을 자동 병합했습니다.\n\n다만 같은 항목을 동시에 수정한 부분 "+conflicts.length+"건은 충돌이 있어 '내 값'을 유지했습니다.\n저장 후 🔄 Refresh로 최종본을 한 번 확인해 주세요.");
      }
    } else if(onDisk && Array.isArray(onDisk.mailSummary)){
      // no teammate edit conflict, but keep Power-Automate-written mail summary
      mailSummary = onDisk.mailSummary;
    }
  }catch(e){ /* proceed with save even if comparison fails */ }

  const stamp = Date.now();
  const writable = await fileHandle.createWritable();
  await writable.write(JSON.stringify({_stamp:stamp, projects, projData, mailSummary}, null, 2));
  await writable.close();
  lastStamp = stamp;
  baseSnapshot = snapshotState();   // disk now matches memory → new common ancestor
  pollBusy = false;
  renderMailSummary();
  return true;
}

async function tryAutoConnect(){
  setConnUI("disconnected");
  if(!FS_SUPPORTED){ render(); return; }
  let h = null;
  try{ h = await idbGet("dataFileHandle"); }catch(e){}
  if(!h){ render(); return; }
  try{
    const perm = await h.queryPermission({mode:"readwrite"});
    if(perm === "granted"){
      fileHandle = h;
      await loadFromFile();
      return;
    }
  }catch(e){}
  setConnUI("need-reconnect", h.name);
  render();
}

