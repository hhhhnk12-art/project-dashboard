/* ── PROJECT FINANCIAL STATUS (all vessels, checkable payment milestones) ── */
function finPct(fs){
  if(!fs) return 0;
  if(fs.allPaid) return 100;
  let c = 0;
  ["dp","delivery","fnbl","retention"].forEach(k=>{ if(fs[k]) c++; });
  return c * 25;
}
function openProjectFinancial(){
  renderProjectFinancial();
  document.getElementById("proj-fin-overlay").classList.add("show");
}
function closeProjectFinancial(){
  document.getElementById("proj-fin-overlay").classList.remove("show");
}
function toggleFinStatus(projId, gIdx, key, val){
  const d = projData[projId];
  if(!d || !d.deliveryChecklist || !d.deliveryChecklist[gIdx]) return;
  const g = d.deliveryChecklist[gIdx];
  if(!g.finStatus) g.finStatus = {};
  g.finStatus[key] = val;
  renderProjectFinancial();
}
function renderProjectFinancial(){
  const wrap = document.getElementById("pf-content");
  if(!wrap) return;

  // group projects by shipyard
  const byYard = {};
  const yardOrder = [];
  projects.forEach(proj=>{
    const d = projData[proj.id];
    if(!d) return;
    const sy = ((d.meta && d.meta.shipyard) || "—");
    if(!byYard[sy]){ byYard[sy] = []; yardOrder.push(sy); }
    byYard[sy].push({proj, d});
  });

  const chk = (projId,gi,k,on)=>`<input type="checkbox" class="pf-chk" ${on?"checked":""} onclick="toggleFinStatus('${projId}',${gi},'${k}',this.checked)">`;
  const rows = [];
  yardOrder.forEach(sy=>{
    const syc = shipyardColor(sy==="—"?"":sy);
    let yardFirst = true;
    byYard[sy].forEach(({proj,d})=>{
      const vessels = d.deliveryChecklist || [];
      let projFirst = true;
      vessels.forEach((g,gi)=>{
        const fs = g.finStatus || {};
        const pct = finPct(fs);
        const rowCls = yardFirst ? "pf-yard-start" : (projFirst ? "pf-proj-start" : "");
        rows.push(`<tr class="${rowCls}" style="background:linear-gradient(90deg, rgba(16,185,129,.20) ${pct}%, transparent ${pct}%);">
          <td class="pf-left">${yardFirst?`<div class="pf-cellpad" style="display:flex;align-items:center;gap:6px;"><span class="sb-dot" style="width:9px;height:9px;background:${syc};flex-shrink:0;"></span><span class="pf-yard">${esc(sy)}</span></div>`:""}</td>
          <td class="pf-left">${projFirst?`<div class="pf-cellpad pf-proj">${esc(proj.name)}</div>`:""}</td>
          <td class="pf-left"><div class="pf-cellpad pf-vessel">${esc(g.name)||"Untitled"}</div></td>
          <td class="pf-chk-cell"><div class="pf-cellpad">${chk(proj.id,gi,"dp",fs.dp)}</div></td>
          <td class="pf-chk-cell"><div class="pf-cellpad">${chk(proj.id,gi,"delivery",fs.delivery)}</div></td>
          <td class="pf-chk-cell"><div class="pf-cellpad">${chk(proj.id,gi,"fnbl",fs.fnbl)}</div></td>
          <td class="pf-chk-cell"><div class="pf-cellpad">${chk(proj.id,gi,"retention",fs.retention)}</div></td>
          <td class="pf-chk-cell"><div class="pf-cellpad">${chk(proj.id,gi,"allPaid",fs.allPaid)}</div></td>
        </tr>`);
        yardFirst = false; projFirst = false;
      });
    });
  });

  const body = rows.length ? rows.join("")
    : `<tr><td colspan="8" style="text-align:center;color:#9ca3af;padding:22px;">Vessel 정보가 없습니다.</td></tr>`;
  wrap.innerHTML = `<table class="pf-tbl">
    <thead><tr>
      <th class="pf-left">Shipyard</th><th class="pf-left">Project</th><th class="pf-left">Vessel</th>
      <th>DP</th><th>Delivery phase</th><th>FNBL</th><th>Retention</th><th>All payment done</th>
    </tr></thead>
    <tbody>${body}</tbody>
  </table>`;
}

