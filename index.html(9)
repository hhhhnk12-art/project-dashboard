}
function setBillingPaid(gi, ii, val){
  const d = getCurrent();
  if(!d || !d.deliveryChecklist || !d.deliveryChecklist[gi] || !d.deliveryChecklist[gi].items[ii]) return;
  d.deliveryChecklist[gi].items[ii].billingPaidDate = val;
  const row = document.getElementById("bil-row-"+gi+"-"+ii);
  if(row) row.classList.toggle("bil-paid", !!(val && String(val).trim()));
}
function getDpPercent(d){
  const terms = (d && d.paymentTerms) || [];
  const t = terms.find(x => String(x.label||"").trim().toUpperCase()==="DP");
  return t ? (Number(t.value)||0) : 0;
}
// thousands separators for display; stores raw (comma-free) value
function fmtThousands(raw){
  if(raw===""||raw==null) return "";
  let s = String(raw);
  const neg = s.trim().startsWith("-");
  s = s.replace(/[^0-9.]/g,"");
  let [intp, ...rest] = s.split(".");
  const decp = rest.length ? rest.join("") : undefined;
  intp = (intp||"").replace(/^0+(?=\d)/,"") || "0";
  intp = intp.replace(/\B(?=(\d{3})+(?!\d))/g, ",");
  return (neg?"-":"") + (decp!==undefined ? intp+"."+decp : intp);
}
function bilNumInput(el, gi, ii, field){
  const d = getCurrent();
  if(!d || !d.deliveryChecklist || !d.deliveryChecklist[gi] || !d.deliveryChecklist[gi].items[ii]) return;
  // keep only digits and a single decimal point
  let raw = el.value.replace(/[^0-9.]/g,"");
  const parts = raw.split(".");
  if(parts.length>2) raw = parts[0]+"."+parts.slice(1).join("");
  d.deliveryChecklist[gi].items[ii][field] = raw;            // store raw number
  el.value = fmtThousands(raw);                               // show with commas
  try{ el.setSelectionRange(el.value.length, el.value.length); }catch(_){}
  if(field==="billingPrice" || field==="billingEquip") updateBilRetention(gi, ii);
}
function updateBilRetention(gi, ii){
  const d = getCurrent();
  const it = d && d.deliveryChecklist && d.deliveryChecklist[gi] && d.deliveryChecklist[gi].items[ii];
  if(!it) return;
  const sf = (typeof getActiveFinancial==="function" ? getActiveFinancial(d) : null) || {};
  const curCode = sf.currency || "USD";
  const sym = (CURRENCY_SYMBOLS && CURRENCY_SYMBOLS[curCode]) || (curCode+" ");
  const fmt = n => sym + (Math.round((Number(n)||0)*100)/100).toLocaleString();
  const price = Number(it.billingPrice)||0;
  const dp    = price * getDpPercent(d) / 100;
  const equip = Number(it.billingEquip)||0;
  const dpCell  = document.getElementById("bil-dp-"+gi+"-"+ii);
  const retCell = document.getElementById("bil-ret-"+gi+"-"+ii);
  if(dpCell)  dpCell.textContent  = fmt(dp);
  if(retCell) retCell.textContent = fmt(price - dp - equip);
}
function toggleBilGrp(gi){
  const d = getCurrent();
  if(!d || !d.deliveryChecklist || !d.deliveryChecklist[gi]) return;
  d.deliveryChecklist[gi].billingCollapsed = !d.deliveryChecklist[gi].billingCollapsed;
