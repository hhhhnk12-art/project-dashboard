function handleAiDrop(ev){
  ev.preventDefault();
  ev.currentTarget.classList.remove("drag-over");
  const f = ev.dataTransfer && ev.dataTransfer.files && ev.dataTransfer.files[0];
  if(f) handleAiFile(f);
}

async function handleAiFile(file){
  if(!file) return;
  document.getElementById("ai-file-name").textContent = "📎 " + file.name;
  aiExtractedText = "";
  const name = (file.name||"").toLowerCase();
  try{
    if(name.endsWith(".pdf") || file.type==="application/pdf"){
      aiSetStatus("PDF 텍스트 추출 중…");
      aiExtractedText = await extractPdfText(file);
      aiSetStatus("✓ PDF 추출 완료 ("+aiExtractedText.length+"자)", "#059669");
    } else if(name.endsWith(".msg")){
      aiSetStatus("⚠️ .msg는 직접 파싱이 제한적입니다. 본문을 붙여넣거나 .eml/.txt/PDF로 저장해 첨부하세요.", "#D97706");
