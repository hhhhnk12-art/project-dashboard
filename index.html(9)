      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;padding:10px 14px;">${rows}</div>`;
    return;
  }

  // Individual series or no-series mode
  const initVal  = Number(sf.baseValue)||0;
  const totalDiff = list.reduce((sum,v)=> sum + voDelta(v), 0);
  const curVal   = initVal + totalDiff;
  const diffClr  = totalDiff>0 ? "#059669" : totalDiff<0 ? "#C2000B" : "#6b7280";

  const highlightHtml = editMode
    ? `<div class="fin-col fin-col-highlight">
