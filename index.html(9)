        return `<tr class="${rowCls}">
          ${warnCell}
          <td class="chk-num-cell">${numField(it.itemNo,"itemNo",ii)}</td>
          <td class="chk-name-cell">${nameCell}</td>
          <td class="chk-date-cell">${dateField(it.fatDate||"","fatDate",ii)}</td>
          <td class="chk-cell">${cellBtn(it.invitation||"X","invitation",ii)}</td>
          ${originCell}
          <td class="chk-date-cell">${dateField(it.siteRequiredDate,"siteRequiredDate",ii)}</td>
          <td class="chk-date-cell">${dateField(it.etaPort||"","etaPort",ii)}</td>
          ${showShippingDoc ? `<td class="chk-cell">${cellBtn(it.shippingDoc,"shippingDoc",ii)}</td>` : ""}
          ${showCustoms     ? `<td class="chk-cell">${cellBtn(it.customs,"customs",ii)}</td>` : ""}
          ${showBondCert    ? `<td class="chk-cell">${cellBtn(it.bondCert||"X","bondCert",ii)}</td>` : ""}
          <td class="chk-cell">${cellBtn(it.delivery,"delivery",ii)}</td>
          <td class="chk-date-cell">${dateField(it.deliveryDate,"deliveryDate",ii)}</td>
          <td class="chk-cell">${cellBtn(it.gr,"gr",ii)}</td>
          <td class="chk-date-cell">${dateField(it.grDate,"grDate",ii)}</td>
