      : `<div style="padding:18px;text-align:center;color:#9ca3af;">등록된 업데이트가 없습니다.</div>`;
    wrap.innerHTML = `
      <button class="btn btn-sm" style="margin-bottom:12px;background:#374151;" onclick="closeIssueDetail()">← 목록으로</button>
