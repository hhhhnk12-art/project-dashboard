/* ── AUTO-SAVE ── */
let autoSaveEnabled = true;
let autoSaveTimer = null;

function setAutoSaveStatus(state){
  const el = document.getElementById("autosave-status");
  if(!el) return;
  if(state==="saving"){ el.textContent = "저장 중…"; el.style.color = "#9ca3af"; }
  else if(state==="saved"){
    const t = new Date();
    const hh = String(t.getHours()).padStart(2,"0"), mm = String(t.getMinutes()).padStart(2,"0");
    el.textContent = `저장됨 ${hh}:${mm}`; el.style.color = "#059669";
  }
  else if(state==="conflict"){ el.textContent = "충돌 — 🔄 후 저장"; el.style.color = "#C2000B"; }
  else if(state==="off"){ el.textContent = ""; }
  else { el.textContent = ""; }
}

function scheduleAutoSave(){
  if(!autoSaveEnabled || !fileHandle) return;
  clearTimeout(autoSaveTimer);
  autoSaveTimer = setTimeout(runAutoSave, 2000); // 2s debounce after last change
}

async function runAutoSave(){
  if(!autoSaveEnabled || !fileHandle) return;
  setAutoSaveStatus("saving");
  let ok = false;
  try{ ok = await writeToFile({silent:true}); }catch(e){ ok = false; }
  setAutoSaveStatus(ok ? "saved" : "conflict");
}

async function toggleAutoSave(on){
  autoSaveEnabled = !!on;
  try{ await idbSet("autoSaveEnabled", autoSaveEnabled ? 1 : 0); }catch(e){}
  if(autoSaveEnabled){ setAutoSaveStatus(""); scheduleAutoSave(); }
  else { clearTimeout(autoSaveTimer); setAutoSaveStatus("off"); }
}

// Detect edits: text/number/select inputs + action buttons
document.addEventListener("input", scheduleAutoSave);
document.addEventListener("change", scheduleAutoSave);
document.addEventListener("click", e=>{ if(e.target.closest && e.target.closest("button")) scheduleAutoSave(); });
// Periodic safety net (covers anything missed) + save once on page hide
setInterval(()=>{ if(autoSaveEnabled && fileHandle) runAutoSave(); }, 60000);
setInterval(()=>{ pollExternalChanges(); }, 12000); // pull teammates' changes in (read-only merge)
window.addEventListener("beforeunload", ()=>{ if(autoSaveEnabled && fileHandle){ try{ writeToFile({silent:true}); }catch(e){} } });

(async ()=>{
  try{
    const v = await idbGet("autoSaveEnabled");
    if(v!=null) autoSaveEnabled = !!(+v);
  }catch(e){}
  const tg = document.getElementById("autosave-toggle");
  if(tg) tg.checked = autoSaveEnabled;
})();

tryAutoConnect();
