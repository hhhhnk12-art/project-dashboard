// Migrate older flat-item data (saved before categories existed) into a single default group
function migrateChecklist(d){
  if(!d.deliveryChecklist){ d.deliveryChecklist = []; return; }
  const list = d.deliveryChecklist;
  if(list.length && list[0] && !("items" in list[0])){
    d.deliveryChecklist = [{id:Date.now(), name:"General", collapsed:true, items:list}];
  }
}

function toggleChecklistCardCollapse(){
  checklistCardCollapsed = !checklistCardCollapsed;
  renderChecklist();
}

function vesselNameFromIndex(hullNum, idx){
  const base = parseInt(hullNum);
  if(!isNaN(base) && base > 0) return String(base + idx);
  return hullNum ? `${hullNum}-${idx+1}` : `Vessel #${idx+1}`;
}

function collapseAllVessels(){
  Object.keys(projData||{}).forEach(id=>{
    const d = projData[id];
    ((d && d.deliveryChecklist) || []).forEach(g=>{ g.collapsed = true; g.billingCollapsed = true; });
  });
}
function migrateIssueStatuses(){
  // "Open" status removed — fold any existing Open issues into "In Progress"
  Object.keys(projData||{}).forEach(id=>{
    const d = projData[id];
    ((d && d.cats) || []).forEach(c=>{
      if(c.status==="Open") c.status = "In Progress";
      (c.issues||[]).forEach(it=>{ if(it.status==="Open") it.status = "In Progress"; });
    });
  });
}
function blankVessel(){
  return { id: Date.now()+Math.floor(Math.random()*100000), name:"", collapsed:true, billingCollapsed:true, poNumber:"", soNumber:"", items: defaultChecklistItems() };
}
function syncDeliveryVessels(d){
  const count = parseInt(d.meta.seriesCount)||0;
  if(!d.deliveryChecklist) d.deliveryChecklist = [];
  if(!count) return; // no series mode: leave checklist as-is

  const prev = d.meta._vesselSyncCount;
  if(prev === undefined){
    // FIRST-TIME setup: create vessels up to the series count
    while(d.deliveryChecklist.length < count) d.deliveryChecklist.push(blankVessel());
    d.meta._vesselSyncCount = count;
    return;
  }
  // Afterwards: only ADD when the user raises the count. Never auto-remove or
  // re-add deleted vessels (so manual deletions persist across renders).
  if(count > prev){
    for(let i=0; i<count-prev; i++) d.deliveryChecklist.push(blankVessel());
  }
  d.meta._vesselSyncCount = count;
}

function renderChecklist(){
  const d = getCurrent(); if(!d) return;
  migrateChecklist(d);
  syncDeliveryVessels(d);
  const groups = d.deliveryChecklist;
