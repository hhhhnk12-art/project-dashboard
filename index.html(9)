let aiExtractedText = "";   // text pulled from an attached file
const AI_DEFAULT_MODEL = { anthropic:"claude-sonnet-4-6", openai:"gpt-4o-mini", gemini:"gemini-2.5-flash", compatible:"llama-3.3-70b-versatile" };
const AI_DEFAULT_BASE  = { compatible:"https://api.groq.com/openai/v1" };
const AI_KEY_LABEL = { anthropic:"Anthropic API Key", openai:"OpenAI API Key", gemini:"Google Gemini API Key", compatible:"API Key (Ollama는 비워도 됨)" };
function aiKeySlot(p){ return p+"Key"; }
function aiModelSlot(p){ return p+"Model"; }
function aiSetStatus(msg, color){ const el=document.getElementById("ai-status"); if(el){ el.textContent=msg||""; el.style.color=color||"#6b7280"; } }

async function fillAiProviderFields(p){
  let key="", model="", base="";
  try{ key = await idbGet(aiKeySlot(p)) || ""; }catch(e){}
  try{ model = await idbGet(aiModelSlot(p)) || ""; }catch(e){}
  try{ base = await idbGet("compatBaseUrl") || ""; }catch(e){}
  document.getElementById("ai-key").value = key;
  document.getElementById("ai-model").value = model || AI_DEFAULT_MODEL[p];
  document.getElementById("ai-model").placeholder = AI_DEFAULT_MODEL[p];
  document.getElementById("ai-key").placeholder = (p==="anthropic") ? "sk-ant-..." : "sk-...";
