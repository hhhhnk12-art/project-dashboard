  document.getElementById("ai-key-status").textContent = key ? "저장된 키 사용 중" : "키가 필요합니다";
  const brow = document.getElementById("ai-baseurl-row");
  brow.style.display = (p==="compatible") ? "block" : "none";
  if(p==="compatible") document.getElementById("ai-baseurl").value = base || AI_DEFAULT_BASE.compatible;
}
async function onAiProviderChange(p){
  try{ await idbSet("aiProvider", p); }catch(e){}
  await fillAiProviderFields(p);
}

async function openAiModal(){
  aiExtractedText = "";
