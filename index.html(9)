function renderBilling(){
  const d = getCurrent();
  const el = document.getElementById("billing-card");
  if(!el) return;
  if(!d){ el.innerHTML = ""; return; }
  const groups = d.deliveryChecklist || [];
  const ox = v => v==="O" ? '<span class="bil-o">O</span>' : '<span class="bil-x">X</span>';

  // currency follows the Financial Aspect card
  const sf = (typeof getActiveFinancial==="function" ? getActiveFinancial(d) : null) || {};
  const curCode = sf.currency || "USD";
  const sym = (CURRENCY_SYMBOLS && CURRENCY_SYMBOLS[curCode]) || "";
  const moneyPrefix = sym || (curCode+" ");
  const fmtBil = n => moneyPrefix + (Math.round((Number(n)||0)*100)/100).toLocaleString();
  const dpPct = getDpPercent(d);   // DP % from Financial Aspect → Payment Terms

  const body = groups.length ? groups.map((g,gi)=>{
    const collapsed = !!g.billingCollapsed;
    const items = (g.items||[]).map((it,ii)=>({it,ii}))
      .filter(x => (String(x.it.name||"").trim().toUpperCase() !== "DP"))   // ITEM 'DP' rows removed
      .filter(x => editMode || !x.it.billingExcluded);  // hide excluded items unless editing
    const rows = items.map(({it,ii})=>{
      const excl = !!it.billingExcluded;
      const price = Number(it.billingPrice)||0;
      const dp    = price * dpPct / 100;
      const equip = Number(it.billingEquip)||0;
      const retention = price - dp - equip;   // DP + 장비납품대금 + 유보금 = PRICE
      const paid = (it.billingPaidDate||"").trim();
      const rowCls = (excl?"bil-excluded ":"") + (paid?"bil-paid":"");
      const actionCell = editMode
        ? `<td class="chk-cell" style="text-align:center;">${excl
            ? `<button class="bil-restore" onclick="restoreBillingItem(${gi},${ii})" title="청구에 복원">↩</button>`
            : `<button class="del-issue-btn" onclick="excludeBillingItem(${gi},${ii})" title="청구에서 제외(삭제)">✕</button>`}</td>`
        : "";
      return `<tr id="bil-row-${gi}-${ii}" class="${rowCls}">
        <td>${esc(it.name)||"-"}</td>
        <td class="chk-cell bil-price-cell">
          <div style="display:flex;align-items:center;gap:4px;">
            <span style="color:#6b7280;font-size:11px;">${sym||curCode}</span>
            <input type="text" inputmode="decimal" class="ei bil-nav bil-num" style="width:100%;text-align:right;" value="${esc(fmtThousands(it.billingPrice))}" placeholder="Price" oninput="bilNumInput(this,${gi},${ii},'billingPrice')">
          </div>
        </td>
        <td id="bil-dp-${gi}-${ii}" class="chk-cell bil-ret-cell" style="text-align:right;font-weight:600;" title="PRICE × DP ${dpPct}%">${fmtBil(dp)}</td>
        <td class="chk-cell bil-money-cell">
          <div style="display:flex;align-items:center;gap:4px;">
            <span style="color:#6b7280;font-size:11px;">${sym||curCode}</span>
            <input type="text" inputmode="decimal" class="ei bil-nav bil-num" style="width:100%;text-align:right;" value="${esc(fmtThousands(it.billingEquip))}" placeholder="0" oninput="bilNumInput(this,${gi},${ii},'billingEquip')">
          </div>
        </td>
        <td id="bil-ret-${gi}-${ii}" class="chk-cell bil-ret-cell" style="text-align:right;font-weight:600;">${fmtBil(retention)}</td>
        <td class="chk-cell bil-rate-cell">
          <input type="text" inputmode="decimal" class="ei bil-nav bil-num" style="width:100%;text-align:right;" value="${esc(fmtThousands(it.billingExRate))}" placeholder="0.00" oninput="bilNumInput(this,${gi},${ii},'billingExRate')">
        </td>
        <td class="chk-cell bil-date-cell">
          <input type="date" class="ei bil-nav" style="width:100%;" value="${esc(it.billingPaidDate)||""}" oninput="setBillingPaid(${gi},${ii},this.value)">
        </td>
        <td class="chk-cell" style="text-align:center;">${ox(it.gr)}</td>
        ${actionCell}
      </tr>`;
    }).join("");
    const colspan = editMode ? 9 : 8;
    return `<div class="chk-grp">
      <div class="chk-grp-hdr" onclick="toggleBilGrp(${gi})">
        <span class="chk-chevron">${collapsed?"▸":"▾"}</span>
        <span class="chk-grp-name">🚢 ${esc(g.name)||"Untitled"}</span>
      </div>
      ${collapsed ? "" : `<div class="chk-grp-body"><div style="overflow-x:auto;"><table class="chk-tbl bil-tbl">
        <thead><tr><th>ITEM</th><th class="bil-price-col">PRICE (${esc(curCode)})</th><th class="bil-money-col">DP (${dpPct}%)</th><th class="bil-money-col">장비납품대금</th><th class="bil-money-col">유보금</th><th class="bil-rate-col">EXCHANGE RATE</th><th class="bil-date-col">입금일</th><th class="chk-col">GR</th>${editMode?'<th class="chk-col"></th>':""}</tr></thead>
        <tbody>${rows||`<tr><td colspan="${colspan}" style="text-align:center;color:#9ca3af;">항목 없음</td></tr>`}</tbody>
      </table></div></div>`}
    </div>`;
  }).join("") : `<div style="padding:10px 2px;color:#9ca3af;font-size:13px;">Delivery 카드에 Vessel이 없습니다.</div>`;

  el.innerHTML = `
    <div class="chk-hdr" style="justify-content:space-between;cursor:pointer;" onclick="toggleBillingCollapse()">
      <span class="sec-lbl" style="margin-bottom:0;display:flex;align-items:center;gap:6px;">
        <span class="chk-chevron">${billingCollapsed?"▸":"▾"}</span>BILLING &amp; PAYMENT
      </span>
    </div>
    ${billingCollapsed ? "" : `<div class="chk-body">${body}</div>`}`;
}
function setBillingPrice(gi, ii, val){
  const d = getCurrent();
  if(!d || !d.deliveryChecklist || !d.deliveryChecklist[gi] || !d.deliveryChecklist[gi].items[ii]) return;
