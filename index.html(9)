    ? `<input class="ei chk-grp-name-input" placeholder="Vessel No." value="${esc(g.name)}" onclick="event.stopPropagation()"
        oninput="getCurrent().deliveryChecklist[${gi}].name=this.value">`
    : `<span class="chk-grp-name">${esc(g.name)||"Untitled"}</span>`;
  const delGroupBtn = `<button class="chk-grp-del" title="이 Vessel 삭제" onclick="event.stopPropagation();deleteChecklistGroup(${gi})">✕</button>`;

  const poSoHtml = `<span class="chk-grp-poso" onclick="event.stopPropagation()">
        <input class="ei chk-poso-input" placeholder="PO No." value="${esc(g.poNumber)}"
          oninput="getCurrent().deliveryChecklist[${gi}].poNumber=this.value">
        <input class="ei chk-poso-input" placeholder="SO No." value="${esc(g.soNumber)}"
          oninput="getCurrent().deliveryChecklist[${gi}].soNumber=this.value">
      </span>`;

  let itemsHtml = "";
  if(!g.collapsed){
    if(!g.items.length){
      itemsHtml = `<div style="padding:8px 0;text-align:center;color:#9ca3af;font-size:13px">No items yet</div>`;
    } else {
      const cellBtn = (val,field,ii)=>{
        const isO = val==="O";
        return `<button class="chk-toggle ${isO?"chk-o":"chk-x"}" onclick="toggleChecklistCell(${gi},${ii},'${field}')">${val||"X"}</button>`;
      };
      const toDateInput = (v)=>{
        if(!v) return "";
        if(/^\d{4}-\d{2}-\d{2}$/.test(v)) return v;          // already ISO
        const dt = new Date(v);
        if(isNaN(dt.getTime())) return "";                    // unparseable → empty picker
        const mm=String(dt.getMonth()+1).padStart(2,"0"), dd=String(dt.getDate()).padStart(2,"0");
        return dt.getFullYear()+"-"+mm+"-"+dd;
      };
      const dateField = (val,field,ii)=>
        `<input type="date" class="ei chk-date-input chk-nav" value="${toDateInput(val)}"
            oninput="getCurrent().deliveryChecklist[${gi}].items[${ii}].${field}=this.value">`;
      const numField = (val,field,ii)=>
        `<input type="number" class="ei chk-num-input chk-nav" value="${val===undefined||val===null||val===""?"":esc(val)}"
            oninput="getCurrent().deliveryChecklist[${gi}].items[${ii}].${field}=this.value">`;

      const incoterms = (getCurrent().incoterms || "FOB").toUpperCase();
      const showShippingDoc = incoterms !== "DDP";
      const showCustoms     = incoterms !== "DAP";
      const showBondCert    = incoterms === "DAP"; // 보세필증

      const ORIGIN_THRESHOLDS = {CN:14, EU:90, KR:7};

      function parseDateOnly(dateStr){
        if(!dateStr) return null;
        const d = new Date(dateStr);
        if(isNaN(d.getTime())) return null;
        d.setHours(0,0,0,0);
        return d;
      }

      // TODAY is recalculated live on every render
      const todayDate = new Date(); todayDate.setHours(0,0,0,0);

      const rows = g.items.map((it,ii)=>{
        const nameCell = editMode
          ? `<input class="ei chk-nav" value="${esc(it.name)}" oninput="getCurrent().deliveryChecklist[${gi}].items[${ii}].name=this.value">`
          : `<span>${esc(it.name)||"—"}</span>`;
