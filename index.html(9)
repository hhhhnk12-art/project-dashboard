/* ── TOTAL ISSUES (all projects' issue-card items, grouped by priority) ── */
const PRIORITY_META = {
  High:   {color:"#C2000B", bg:"#FEF2F2", rank:0, label:"HIGH"},
  Medium: {color:"#D97706", bg:"#FFFBEB", rank:1, label:"MEDIUM"},
  Low:    {color:"#059669", bg:"#ECFDF5", rank:2, label:"LOW"},
};
function priMeta(p){
  return PRIORITY_META[p] || {color:"#6b7280", bg:"#f3f4f6", rank:9, label:String(p||"OTHER").toUpperCase()};
}
function gatherIssueItems(){
  const out = [];
  projects.forEach(proj=>{
    const d = projData[proj.id];
    if(!d || !d.cats) return;
    d.cats.forEach(cat=>{
      const updates = (cat.issues||[]).map(iss=>({
        date: iss.date||"", desc: iss.desc||"", photo: iss.photo||""
      }));
      const last = updates.length ? updates[updates.length-1] : null;
      out.push({
        projId: proj.id,
        project: proj.name,
        shipyard: (d.meta&&d.meta.shipyard)||"",
        category: cat.name||"—",
        catStatus: cat.status||"",
        priority: cat.priority||"Medium",
        updates,
        updateCount: updates.length,
        lastDate: last ? (last.date||"") : "",
        latestDesc: last ? (last.desc||"") : ""
      });
    });
  });
  return out;
}
let tiFilter = "all";       // "all" | "High" | "Medium" | "Low" | ...
let tiStatusFilter = "all"; // "all" | "Open" | "In Progress" | "Closed"
let tiSelected = null;      // index into tiItemsCache for detail view
let tiItemsCache = [];

function tiSetFilter(p){ tiFilter = p; tiSelected = null; renderTotalIssues(); }
function tiSetStatus(v){ tiStatusFilter = v; tiSelected = null; renderTotalIssues(); }
function openIssueDetail(idx){ tiSelected = idx; renderTotalIssues(); }
function closeIssueDetail(){ tiSelected = null; renderTotalIssues(); }

function renderTotalIssues(){
