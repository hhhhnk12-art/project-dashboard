        const rowCls = it.delivery==="O" ? "chk-row-done" : "";

        // Warning: Site Required Date - TODAY vs threshold
        const origin = it.origin||"CN";
        const threshold = ORIGIN_THRESHOLDS[origin]??14;
        const siteDate = parseDateOnly(it.siteRequiredDate);
        const daysLeft = siteDate ? Math.floor((siteDate - todayDate) / (1000*60*60*24)) : null;
        const warn = daysLeft!==null && daysLeft<=threshold && it.delivery!=="O";
        const overdue = warn && daysLeft<0;
        const warnTitle = daysLeft!==null
          ? (overdue ? `D+${Math.abs(daysLeft)} 초과! (${origin} 기준 ${threshold}일 이하 경고)` : `D-${daysLeft} 남음 (${origin} 기준 ${threshold}일 이하 경고)`)
