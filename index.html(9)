    return `<tr><td>${esc(c.name)}</td><td class="c">${esc(c.priority)}</td><td class="c">${esc(c.status)}</td><td class="c">${esc(open)||"-"}</td><td>${last&&last.desc?esc(last.desc):"-"}</td></tr>`;
