        const warnCell = warn
          ? `<td class="chk-warn-cell" title="${warnTitle}"><span class="chk-warn-badge${overdue?" chk-warn-overdue":""}">${overdue?"OVER":"D-"+daysLeft}</span></td>`
          : `<td class="chk-warn-cell"></td>`;

        const originCell = `<td class="chk-cell">
          <select class="esel" style="font-size:11px;padding:1px 3px;"
            onchange="getCurrent().deliveryChecklist[${gi}].items[${ii}].origin=this.value;renderChecklist()">
