async function extractPdfText(file){
  if(!window.pdfjsLib){
    await loadScript("https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js");
  }
  window.pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
  const buf = await file.arrayBuffer();
  const pdf = await window.pdfjsLib.getDocument({data:buf}).promise;
  let text="";
  for(let i=1;i<=pdf.numPages;i++){
    const page = await pdf.getPage(i);
    const c = await page.getTextContent();
    text += c.items.map(it=>it.str).join(" ") + "\n";
  }
  return text.trim();
}

async function runAiSummary(){
  const d = getCurrent();
  if(!d){ aiSetStatus("프로젝트를 먼저 선택하세요.", "#C2000B"); return; }
  const pasted = document.getElementById("ai-text").value.trim();
  const source = (aiExtractedText + "\n" + pasted).trim();
  if(!source){ aiSetStatus("첨부 파일이나 붙여넣은 텍스트가 필요합니다.", "#C2000B"); return; }

  const provider = document.getElementById("ai-provider").value || "gemini";
  let key="", model="", base="";
  try{ key = await idbGet(aiKeySlot(provider)) || ""; }catch(e){}
  try{ model = await idbGet(aiModelSlot(provider)) || AI_DEFAULT_MODEL[provider]; }catch(e){}
  try{ base = await idbGet("compatBaseUrl") || ""; }catch(e){}
  if(!key){
    key = document.getElementById("ai-key").value.trim();
    if(provider==="compatible" && !base) base = document.getElementById("ai-baseurl").value.trim();
    if(key || provider==="compatible") await saveAiKey();
  }
  const ollamaLocal = provider==="compatible" && /localhost|127\.0\.0\.1/.test(base||"");
  if(!key && !ollamaLocal){ aiSetStatus((AI_KEY_LABEL[provider]||"API")+" 키를 입력하고 저장하세요.", "#C2000B"); return; }

  const btn = document.getElementById("ai-run-btn");
  btn.disabled = true;
  aiSetStatus("AI 요약 중… (잠시 기다려주세요)", "#2563EB");

  const today = new Date().toLocaleDateString("en-CA");
  const customInstr = (document.getElementById("ai-prompt").value || "").trim();
  try{ await idbSet("aiPrompt", customInstr); }catch(e){}
  const prompt = "You are a PM assistant for shipbuilding / marine projects. Analyze the document or email below and organize it into a single issue / requirement item.\n"
    + "Output ONLY one JSON object (no markdown, no explanation, no code fences):\n"
    + '{"title":"concise title, max 40 chars","priority":"High|Medium|Low","status":"In Progress|Closed","date":"'+today+'","summary":"3-5 sentence summary in English, including key actions / requirements / deadlines"}\n'
    + (customInstr ? ("\nAdditional instructions (follow these, they override the defaults above including output language): " + customInstr + "\n") : "")
    + "\nDocument:\n<<<\n" + source.slice(0, 12000) + "\n>>>";

  try{
    let out = "";
    if(provider==="gemini"){
      const gm = model||AI_DEFAULT_MODEL.gemini;
      const res = await fetch("https://generativelanguage.googleapis.com/v1beta/models/"+gm+":generateContent", {
        method:"POST",
        headers:{ "content-type":"application/json", "x-goog-api-key": key },
        body: JSON.stringify({ contents:[{ parts:[{text:prompt}] }] })
      });
      if(!res.ok){ let msg="HTTP "+res.status; try{ const e=await res.json(); if(e.error&&e.error.message) msg=e.error.message; }catch(_){ } throw new Error(msg); }
      const data = await res.json();
      out = (((((data.candidates||[])[0]||{}).content||{}).parts||[]).map(p=>p.text||"").join("")) || "";
    } else if(provider==="anthropic"){
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{ "content-type":"application/json", "x-api-key": key, "anthropic-version":"2023-06-01", "anthropic-dangerous-direct-browser-access":"true" },
        body: JSON.stringify({ model: model||AI_DEFAULT_MODEL.anthropic, max_tokens:1024, messages:[{role:"user", content:prompt}] })
      });
      if(!res.ok){ let msg="HTTP "+res.status; try{ const e=await res.json(); if(e.error&&e.error.message) msg=e.error.message; }catch(_){ } throw new Error(msg); }
      const data = await res.json();
      out = (data.content||[]).map(b=>b.text||"").join("");
    } else { // openai OR compatible (Groq/OpenRouter/Ollama) — OpenAI-compatible /chat/completions
      const baseUrl = (provider==="compatible") ? (base||AI_DEFAULT_BASE.compatible).replace(/\/+$/,"") : "https://api.openai.com/v1";
      const headers = { "content-type":"application/json" };
      if(key) headers["authorization"] = "Bearer "+key;
      const res = await fetch(baseUrl+"/chat/completions", {
        method:"POST", headers,
        body: JSON.stringify({ model: model||AI_DEFAULT_MODEL[provider]||AI_DEFAULT_MODEL.openai, max_tokens:1024, messages:[{role:"user", content:prompt}] })
      });
      if(!res.ok){ let msg="HTTP "+res.status; try{ const e=await res.json(); if(e.error&&e.error.message) msg=e.error.message; }catch(_){ } throw new Error(msg); }
      const data = await res.json();
      out = (((data.choices||[])[0]||{}).message||{}).content || "";
    }
    out = (out||"").trim().replace(/^```json\s*/i,"").replace(/^```\s*/i,"").replace(/```$/,"").trim();
    let j;
    try{ j = JSON.parse(out); }
    catch(_){ const mt = out.match(/\{[\s\S]*\}/); if(mt) j = JSON.parse(mt[0]); }
    if(!j || !j.title){ throw new Error("응답을 해석하지 못했습니다."); }

    const pri = ["High","Medium","Low"].includes(j.priority) ? j.priority : "Medium";
    const st  = ["In Progress","Closed"].includes(j.status) ? j.status : "In Progress";
    const cat = {
      id: Date.now(), name: String(j.title).slice(0,60), priority: pri, status: st,
      openDate: j.date || today, owner: "",
      issues: [{ id:"U-"+Date.now()%100000, date: j.date || today, desc: String(j.summary||""), photo:"" }]
    };
    if(!d.cats) d.cats = [];
    d.cats.push(cat);
    renderCats();
    aiSetStatus("✓ 이슈 추가 완료: "+cat.name, "#059669");
    setTimeout(closeAiModal, 900);
  }catch(e){
    aiSetStatus("요약 실패: "+(e&&e.message||e), "#C2000B");
  }finally{
    btn.disabled = false;
  }
}

