  const monLabel = now.toLocaleDateString("en-US",{month:"long",year:"numeric"});
  const ox = v => v ? "<span class='ox o'>O</span>" : "<span class='ox x'>–</span>";

  // ── 1. Total Delivery — delivery date in current month ──
  const dRows = (typeof gatherDeliveryRows==="function" ? gatherDeliveryRows() : []).filter(r=>{
    const dt = parseTdDate(r.deliveryDate);
    return dt && dt.getMonth()===now.getMonth() && dt.getFullYear()===now.getFullYear();
  }).sort((a,b)=> (parseTdDate(a.deliveryDate)-parseTdDate(b.deliveryDate)));
  const delRows = dRows.length ? dRows.map(r=>
    `<tr><td>${esc(r.shipyard)||"—"}</td><td>${esc(r.project)}</td><td>${esc(r.vessel)}</td><td>${esc(r.item)}</td>`
    + `<td class="c">${esc(r.origin)||"—"}</td><td class="c">${esc(r.siteRequiredDate)||"—"}</td>`
    + `<td class="c">${esc(r.etaPort)||"—"}</td><td class="c" style="font-weight:700;">${esc(r.deliveryDate)||"—"}</td>`
    + `<td class="c">${ox(r.gr==="O")}</td></tr>`).join("")
    : `<tr><td colspan="9" class="c">해당 월 납품 예정 항목이 없습니다.</td></tr>`;

  // ── 2. Project Execution Status (compact horizontal timeline per project) ──
  const execHtml = projects.length ? projects.map(p=>{
    const d = projData[p.id];
    if(!d) return `<div class="exec-row"><div class="exec-row-head"><span class="exec-name">${esc(p.name)}</span> <span class="tag">미로드</span></div></div>`;
    const m = d.meta||{};
    const riskColorMap = {RED:"#C2000B", AMBER:"#D97706", GREEN:"#059669"};
    const rc = riskColorMap[String(m.risk||"").toUpperCase()] || "#6b7280";
    const prog = isAutoProgress(d) ? computeStageOverall(d) : (Number(m.progress)||0);
    const segs = (d.stages||[]).map(s=>{
      const st = String(s.status||"").toLowerCase();
      const pct = s.status==="done" ? 100 : (Number(s.pct)||0);
      const cls = st==="done" ? "done" : (st==="active" ? "act" : "pend");
      return `<div class="exseg ${cls}"><span class="sn">${esc(s.name)}</span><span class="sp">${pct}%</span>${s.date?`<span class="sd">${esc(s.date)}</span>`:""}</div>`;
    }).join('<span class="exarr">›</span>') || `<span style="color:#9ca3af;font-size:11px;">단계 없음</span>`;
    return `<div class="exec-row">
      <div class="exec-row-head">
        <span class="exec-name">${esc(m.name||p.name)}</span>
        ${m.shipyard?`<span class="tag">${esc(m.shipyard)}</span>`:""}
        <span class="exec-risk" style="background:${rc};">${esc(m.risk)||"—"}</span>
        ${m.milestone?`<span class="exmile">🏁 ${esc(m.milestone)}</span>`:""}
        <span class="exec-prog"><span class="exec-bar"><span style="width:${prog}%;"></span></span>${prog}%</span>
      </div>
      <div class="exec-strip">${segs}</div>
    </div>`;
  }).join("") : `<p>프로젝트가 없습니다.</p>`;

  // ── 3. Project Financial Status (grouped by shipyard, continuous) ──
  const byYard = {}; const yardOrder = [];
