/* ── 3-way merge helpers (optimistic concurrency) ── */
function deepClone(o){ return o==null ? o : JSON.parse(JSON.stringify(o)); }
function _eqJSON(a,b){ return JSON.stringify(a)===JSON.stringify(b); }
function _isPlainObj(x){ return x && typeof x==="object" && !Array.isArray(x); }
function snapshotState(){ return deepClone({ projects, projData, mailSummary }); }
function hasLocalChanges(){ return baseSnapshot && !_eqJSON(snapshotState(), baseSnapshot); }

// merge3: base = common ancestor, mine = my current, theirs = latest on disk.
// Returns merged value; pushes dotted paths of true same-field conflicts into `conflicts`.
function merge3(base, mine, theirs, path, conflicts){
  if(_eqJSON(mine, theirs)) return deepClone(mine);
  if(_eqJSON(base, mine))   return deepClone(theirs);  // only they changed → take theirs
  if(_eqJSON(base, theirs)) return deepClone(mine);    // only I changed → take mine

  // both sides changed
  if(_isPlainObj(mine) && _isPlainObj(theirs)){
    const baseO = _isPlainObj(base) ? base : {};
    const out = {};
    const keys = new Set([...Object.keys(mine), ...Object.keys(theirs)]);
    keys.forEach(k=>{
      const inM = k in mine, inT = k in theirs, inB = k in baseO;
      if(inM && inT)        out[k] = merge3(baseO[k], mine[k], theirs[k], path+"."+k, conflicts);
      else if(inM && !inT){ if(!(inB && _eqJSON(baseO[k], mine[k]))) out[k] = deepClone(mine[k]); } // they removed; keep only if I changed/added
      else if(!inM && inT){ if(!(inB && _eqJSON(baseO[k], theirs[k]))) out[k] = deepClone(theirs[k]); } // I removed; keep only if they changed/added
    });
    return out;
  }

  if(Array.isArray(mine) && Array.isArray(theirs)){
    const idable = mine.every(e=>e&&typeof e==="object"&&e.id!=null) && theirs.every(e=>e&&typeof e==="object"&&e.id!=null);
    if(idable){
      const baseArr = Array.isArray(base) ? base : [];
      const bById={}, mById={}, tById={};
      baseArr.forEach(e=>bById[e.id]=e); mine.forEach(e=>mById[e.id]=e); theirs.forEach(e=>tById[e.id]=e);
      const order=[]; mine.forEach(e=>{ if(!order.includes(e.id)) order.push(e.id); });
      theirs.forEach(e=>{ if(!order.includes(e.id)) order.push(e.id); });
      const out=[];
      order.forEach(id=>{
        const b=bById[id], m=mById[id], t=tById[id];
        if(m && t)        out.push(merge3(b, m, t, path+"["+id+"]", conflicts));
        else if(m && !t){ if(!(b && _eqJSON(b,m))) out.push(deepClone(m)); }  // they deleted; keep only if I changed
        else if(!m && t){ if(!(b && _eqJSON(b,t))) out.push(deepClone(t)); }  // I deleted; keep only if they changed
      });
      return out;
    }
    conflicts.push(path||"(list)");   // arrays without ids, both changed
    return deepClone(mine);
  }

  conflicts.push(path||"(value)");    // primitives changed on both sides
  return deepClone(mine);
}

// Fold the latest on-disk state into memory via 3-way merge. Returns {conflicts:[]}.
function mergeDiskIntoMemory(onDisk){
  const base   = baseSnapshot || snapshotState();
  const mine    = { projects, projData, mailSummary };
  const theirs  = { projects: deepClone(onDisk.projects)||[], projData: deepClone(onDisk.projData)||{}, mailSummary: Array.isArray(onDisk.mailSummary)?deepClone(onDisk.mailSummary):[] };
  const conflicts = [];
  const merged = merge3(base, mine, theirs, "", conflicts);
  projects    = merged.projects || [];
  projData    = merged.projData || {};
  mailSummary = merged.mailSummary || [];
  if(activeId && !projData[activeId]) activeId = (projects[0] && projects[0].id) || null;
  baseSnapshot = deepClone(theirs);            // common ancestor going forward = the disk version
  if(onDisk._stamp) lastStamp = onDisk._stamp; // I am now synced to this disk revision
  return { conflicts };
}

// Read-only poll: pull teammates' changes in automatically (every few seconds).
async function pollExternalChanges(){
  if(!fileHandle || pollBusy) return;
  // don't disrupt the user while they're typing into a field
  const ae = document.activeElement;
  if(ae && (ae.tagName==="INPUT" || ae.tagName==="TEXTAREA" || ae.tagName==="SELECT")) return;
  pollBusy = true;
  try{
    const perm = await fileHandle.queryPermission({mode:"read"});
    if(perm!=="granted"){ pollBusy=false; return; }
    const file = await fileHandle.getFile();
    const text = await file.text();
    const onDisk = text.trim() ? JSON.parse(text) : null;
    if(onDisk && onDisk._stamp && lastStamp && onDisk._stamp !== lastStamp){
      const { conflicts } = mergeDiskIntoMemory(onDisk);
      render();
      setAutoSaveStatus("🔄 팀원 변경 반영됨"+(conflicts.length?` (충돌 ${conflicts.length}건은 내 값 유지)`:""));
      setTimeout(()=>setAutoSaveStatus(""), 4000);
    }
  }catch(e){ /* ignore transient read/parse errors during sync */ }
  pollBusy = false;
}

// --- Save the file handle in IndexedDB so the same browser can auto-reconnect next time ---
function idbOpen(){
  return new Promise((res,rej)=>{
    const req = indexedDB.open("dash-fs-db",1);
    req.onupgradeneeded = ()=> req.result.createObjectStore("kv");
    req.onsuccess = ()=> res(req.result);
    req.onerror = ()=> rej(req.error);
  });
}
async function idbSet(k,v){
  const db = await idbOpen();
  return new Promise((res)=>{
    const tx = db.transaction("kv","readwrite");
    tx.objectStore("kv").put(v,k);
    tx.oncomplete = ()=>res();
  });
}
async function idbGet(k){
  const db = await idbOpen();
  return new Promise((res)=>{
    const tx = db.transaction("kv","readonly");
    const req = tx.objectStore("kv").get(k);
    req.onsuccess = ()=> res(req.result||null);
    req.onerror = ()=> res(null);
  });
}

function setConnUI(state, name){
  const icon = document.getElementById("file-conn-icon");
  const status = document.getElementById("file-conn-status");
  const refreshBtn = document.getElementById("refresh-btn");
  const topSaveBtn = document.getElementById("top-save-btn");
  const autosaveLabel = document.getElementById("autosave-label");
  if(state==="connected"){
    icon.textContent = "🟢";
    status.textContent = "Connected: " + name;
    refreshBtn.style.display = "inline-block";
    if(topSaveBtn) topSaveBtn.style.display = "inline-block";
    if(autosaveLabel) autosaveLabel.style.display = "inline-flex";
  } else if(state==="need-reconnect"){
    icon.textContent = "🟡";
    status.textContent = name + " — Permission needs to be reconfirmed. Please click 'Open Existing File' again.";
    refreshBtn.style.display = "none";
    if(topSaveBtn) topSaveBtn.style.display = "none";
    if(autosaveLabel) autosaveLabel.style.display = "none";
  } else {
    icon.textContent = "⚪";
    status.textContent = FS_SUPPORTED
      ? "Not connected to a data file"
      : "This browser is not supported. Please open this in the latest version of Edge.";
    refreshBtn.style.display = "none";
    if(topSaveBtn) topSaveBtn.style.display = "none";
    if(autosaveLabel) autosaveLabel.style.display = "none";
  }
}

