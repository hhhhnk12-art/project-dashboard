// STORAGE  (read/write directly to a JSON file in a SharePoint/OneDrive synced folder)
// ═══════════════════════════════════════════
let fileHandle = null;
let lastStamp = null; // for conflict detection: timestamp of the last save I read or wrote
let baseSnapshot = null; // common ancestor (state as loaded/last-synced) for 3-way merge
let pollBusy = false;    // guard so polling and saving don't overlap
