function setUpdatePhotoFile(catIdx, issueIdx, file){
  if(!file || !file.type || !file.type.startsWith("image/")) return;
  const reader = new FileReader();
  reader.onload = function(e){
    getCurrent().cats[catIdx].issues[issueIdx].photo = e.target.result;
